            Pl => table { P1 => aorT+"ëm" ; P2 => aorT+"ët" ; P3 => aorT+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => root+"ja" ; P2 => root+"je" ; P3 => root+"nte" } ;
            Pl => table { P1 => root+"nim" ; P2 => root+"nit" ; P3 => root+"nin" }
          }
        } ;

        Imperative = table { Sg => root+"j" ; Pl => root+"ni" } ;

        participle = part ;

        pres_optative = table {
          Sg => table { P1 => aorT+"sha" ; P2 => aorT+"sh" ; P3 => aorT+"të" } ;
          Pl => table { P1 => aorT+"shim" ; P2 => aorT+"shi" ; P3 => aorT+"shin" }
        } ;

        perf_optative = table {
          Sg => table { P1 => "paça " + part ; P2 => "paç " + part ; P3 => "pastë " + part } ;
          Pl => table { P1 => "paçim " + part ; P2 => "paçi " + part ; P3 => "paçin " + part }
        } ;

        pres_admirative = table {
          Sg => table { P1 => short+"kam" ; P2 => short+"ke" ; P3 => short+"ka" } ;
          Pl => table { P1 => short+"kemi" ; P2 => short+"keni" ; P3 => short+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => short+"kësha" ; P2 => short+"këshe" ; P3 => short+"kësh" } ;
          Pl => table { P1 => short+"këshim" ; P2 => short+"këshit" ; P3 => short+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV068"
  } ;

mkV069 : Str -> V ;
mkV069 base =
  case base of {
    root+"n" =>
      let pres2 : Str = root+"n" ;
          part  : Str = root+"të" ;
          short : Str = <case part of { p+"ë" => p ; p+"r" => p ; _ => part } : Str> ;
          aorT  : Str = root+"t" ;
      in lin V {
        Indicative = table {
          Pres => table { -- treat as hyj-type given in 3sg: hyn / hyj / hyjmë / hyni / hyjnë
            Sg => table { P1 => root+"j" ; P2 => pres2 ; P3 => pres2 } ;
            Pl => table { P1 => root+"jmë" ; P2 => root+"ni" ; P3 => root+"jnë" }
          } ;
          Past => table {
            Sg => table { P1 => "kam " + part ; P2 => "ke " + part ; P3 => "ka " + part } ;
            Pl => table { P1 => "kemi " + part ; P2 => "keni " + part ; P3 => "kanë " + part }
          } ;
          Aorist => table { -- keep your 1sg -ti, extend as t-aorist
            Sg => table { P1 => aorT+"i" ; P2 => aorT+"e" ; P3 => aorT+"i" } ;
            Pl => table { P1 => aorT+"ëm" ; P2 => aorT+"ët" ; P3 => aorT+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => root+"ja" ; P2 => root+"je" ; P3 => root+"nte" } ;
            Pl => table { P1 => root+"nim" ; P2 => root+"nit" ; P3 => root+"nin" }
          }
        } ;

        Imperative = table { Sg => root+"j" ; Pl => root+"ni" } ;

        participle = part ;

        pres_optative = table {
          Sg => table { P1 => aorT+"sha" ; P2 => aorT+"sh" ; P3 => aorT+"të" } ;
          Pl => table { P1 => aorT+"shim" ; P2 => aorT+"shi" ; P3 => aorT+"shin" }
        } ;

        perf_optative = table {
          Sg => table { P1 => "paça " + part ; P2 => "paç " + part ; P3 => "pastë " + part } ;
          Pl => table { P1 => "paçim " + part ; P2 => "paçi " + part ; P3 => "paçin " + part }
        } ;

        pres_admirative = table {
          Sg => table { P1 => short+"kam" ; P2 => short+"ke" ; P3 => short+"ka" } ;
          Pl => table { P1 => short+"kemi" ; P2 => short+"keni" ; P3 => short+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => short+"kësha" ; P2 => short+"këshe" ; P3 => short+"kësh" } ;
          Pl => table { P1 => short+"këshim" ; P2 => short+"këshit" ; P3 => short+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV069"
  } ;

mkV070 : Str -> V ;
mkV070 base =
  case base of {
    root+"on" =>
      let part  : Str = root+"uar" ;
          short : Str = root+"ua" ; -- punuar -> punua-
      in lin V {
        Indicative = table {
          Pres => table { -- punoj/punon/punon/punojmë/punoni/punojnë 
            Sg => table { P1 => root+"oj" ; P2 => root+"on" ; P3 => root+"on" } ;
            Pl => table { P1 => root+"ojmë" ; P2 => root+"oni" ; P3 => root+"ojnë" }
          } ;
          Past => table { -- kam punuar 
            Sg => table { P1 => "kam " + part ; P2 => "ke " + part ; P3 => "ka " + part } ;
            Pl => table { P1 => "kemi " + part ; P2 => "keni " + part ; P3 => "kanë " + part }
          } ;
          Aorist => table { -- punova/punove/punoi/punuam/punuat/punuan 
            Sg => table { P1 => root+"ova" ; P2 => root+"ove" ; P3 => root+"oi" } ;
            Pl => table { P1 => root+"uam" ; P2 => root+"uat" ; P3 => root+"uan" }
          } ;
          Imperfect => table { -- punoja/punoje/punonte/punonim/punonit/punonin 
            Sg => table { P1 => root+"oja" ; P2 => root+"oje" ; P3 => root+"onte" } ;
            Pl => table { P1 => root+"onim" ; P2 => root+"onit" ; P3 => root+"onin" }
          }
        } ;

        Imperative = table { -- puno / punoni 
          Sg => root+"o" ;
          Pl => root+"oni"
        } ;

        participle = part ;

        pres_optative = table { -- punofsha... 
          Sg => table { P1 => root+"ofsha" ; P2 => root+"ofsh" ; P3 => root+"oftë" } ;
          Pl => table { P1 => root+"ofshim" ; P2 => root+"ofshi" ; P3 => root+"ofshin" }
        } ;

        perf_optative = table {
          Sg => table { P1 => "paça " + part ; P2 => "paç " + part ; P3 => "pastë " + part } ;
          Pl => table { P1 => "paçim " + part ; P2 => "paçi " + part ; P3 => "paçin " + part }
        } ;

        pres_admirative = table { -- punuakam... 
          Sg => table { P1 => short+"kam" ; P2 => short+"ke" ; P3 => short+"ka" } ;
          Pl => table { P1 => short+"kemi" ; P2 => short+"keni" ; P3 => short+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => short+"kësha" ; P2 => short+"këshe" ; P3 => short+"kësh" } ;
          Pl => table { P1 => short+"këshim" ; P2 => short+"këshit" ; P3 => short+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV070"
  } ;

mkV071 : Str -> V ;
mkV071 base =
  case base of {
    base_1+base_2@?+"j" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+base_2+"j" ;
                                         P2 => base_1+base_2+"n" ;
                                         P3 => base_1+base_2+"n"
                                       } ;
                                 Pl => table {
                                         P1 => base_1+base_2+"jmë" ;
                                         P2 => base_1+base_2+"ni" ;
                                         P3 => base_1+base_2+"jnë"
                                       }
                               } ;
                       Past => table {
                                 Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                                 Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+base_2+"va" ;
                                           P2 => base_1+base_2+"ve" ;
                                           P3 => base_1+base_2+"u"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"y"+base_2+"m" ;
                                           P2 => base_1+"y"+base_2+"t" ;
                                           P3 => base_1+"y"+base_2+"n"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+base_2+"ja" ;
                                              P2 => base_1+base_2+"je" ;
                                              P3 => base_1+base_2+"nte"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+base_2+"nim" ;
                                              P2 => base_1+base_2+"nit" ;
                                              P3 => base_1+base_2+"nin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+base_2 ;
                       Pl => base_1+base_2+"ni"
                     } ;
        participle = base_1+"y"+base_2+"r" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => base_1+base_2+"fsha" ;
                                  P2 => base_1+base_2+"fsh" ;
                                  P3 => base_1+base_2+"ftë"
                                } ;
                          Pl => table {
                                  P1 => base_1+base_2+"fshim" ;
                                  P2 => base_1+base_2+"fshi" ;
                                  P3 => base_1+base_2+"fshin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table {
                                  P1 => "paça"+" "+(base_1+"y"+base_2+"r") ;
                                  P2 => "paç"+" "+(base_1+"y"+base_2+"r") ;
                                  P3 => "pastë"+" "+(base_1+"y"+base_2+"r")
                                } ;
                          Pl => table {
                                  P1 => "paçim"+" "+(base_1+"y"+base_2+"r") ;
                                  P2 => "paçi"+" "+(base_1+"y"+base_2+"r") ;
                                  P3 => "paçin"+" "+(base_1+"y"+base_2+"r")
                                }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => base_1+"y"+base_2+"kam" ;
                                    P2 => base_1+"y"+base_2+"ke" ;
                                    P3 => base_1+"y"+base_2+"ka"
                                  } ;
                            Pl => table {
                                    P1 => base_1+"y"+base_2+"kemi" ;
                                    P2 => base_1+"y"+base_2+"keni" ;
                                    P3 => base_1+"y"+base_2+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => base_1+"y"+base_2+"kësha" ;
                                      P2 => base_1+"y"+base_2+"këshe" ;
                                      P3 => base_1+"y"+base_2+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => base_1+"y"+base_2+"këshim" ;
                                      P2 => base_1+"y"+base_2+"këshit" ;
                                      P3 => base_1+"y"+base_2+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV071"
  } ;

mkV072 : Str -> V ;
mkV072 base =
  case base of {
    base_1+base_2@?+"s" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+base_2+"s" ;
                                         P2 => base_1+base_2+"s" ;
                                         P3 => base_1+base_2+"s"
                                       } ;
                                 Pl => table {
                                         P1 => base_1+base_2+"sim" ;
                                         P2 => base_1+base_2+"sni" ;
                                         P3 => base_1+base_2+"sin"
                                       }
