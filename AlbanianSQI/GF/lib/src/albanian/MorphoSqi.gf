mkV096 : Str -> V ;
mkV096 base =
  case base of {
    base_1+"ohem" =>
      let
        -- present/imperfect are non-active (ohem family)
        part    = base_1+"uar" ;
        admStem = base_1+"ua" ;
        aorStem = base_1+"ov" ;
        optBase = base_1+"of"
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table {
              P1 => base_1+"ohem" ;
              P2 => base_1+"ohesh" ;
              P3 => base_1+"ohet"
            } ;
            Pl => table {
              P1 => base_1+"ohemi" ;
              P2 => base_1+"oheni" ;
              P3 => base_1+"ohen"
            }
          } ;
          Past => table { -- perfect (non-active uses jam)
            Sg => table {
              P1 => "jam"+" "+part ;
              P2 => "je"+" "+part ;
              P3 => "është"+" "+part
            } ;
            Pl => table {
              P1 => "jemi"+" "+part ;
              P2 => "jeni"+" "+part ;
              P3 => "janë"+" "+part
            }
          } ;
          Aorist => table { -- aorist stem (still stored without u-)
            Sg => table {
              P1 => aorStem+"a" ;
              P2 => aorStem+"e" ;
              P3 => aorStem+"i"
            } ;
            Pl => table {
              P1 => aorStem+"ëm" ;
              P2 => aorStem+"ët" ;
              P3 => aorStem+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table {
              P1 => base_1+"ohesha" ;
              P2 => base_1+"oheshe" ;
              P3 => base_1+"ohej"
            } ;
            Pl => table {
              P1 => base_1+"oheshim" ;
              P2 => base_1+"oheshit" ;
              P3 => base_1+"oheshin"
            }
          }
        } ;

        Imperative = table {
          Sg => base_1+"ohu" ;
          Pl => base_1+"ohuni"
        } ;

        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optBase+"sha" ;
            P2 => optBase+"sh" ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optBase+"shim" ;
            P2 => optBase+"shi" ;
            P3 => optBase+"shin"
          }
        } ;

        perf_optative = table { -- perfect optative (non-active uses qof-)
          Sg => table {
            P1 => "qofsha"+" "+part ;
            P2 => "qofsh"+" "+part ;
            P3 => "qoftë"+" "+part
          } ;
          Pl => table {
            P1 => "qofshim"+" "+part ;
            P2 => "qofshi"+" "+part ;
            P3 => "qofshin"+" "+part
          }
        } ;

        pres_admirative = table {
          Sg => table {
            P1 => admStem+"kam" ;
            P2 => admStem+"ke" ;
            P3 => admStem+"ka"
          } ;
          Pl => table {
            P1 => admStem+"kemi" ;
            P2 => admStem+"keni" ;
            P3 => admStem+"kan"
          }
        } ;

        imperf_admirative = table {
          Sg => table {
            P1 => admStem+"kësha" ;
            P2 => admStem+"këshe" ;
            P3 => admStem+"kësh"
          } ;
          Pl => table {
            P1 => admStem+"këshim" ;
            P2 => admStem+"këshit" ;
            P3 => admStem+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV096"
  } ;

mkV097 : Str -> V ;
mkV097 base =
  case base of {
    base_1+base_2@?+"hem" =>
