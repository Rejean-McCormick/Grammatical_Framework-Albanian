mkV087 : Str -> V ;
mkV087 base =
  case base of {
    base_1 + "h" + base_2@? + "ë" + base_3@(?+?) + "as" =>
      let pres1 = base_1 + "h" + base_2 + "ë" + base_3 + "as" ;
          aor1  = base_1 + "h" + base_2 + "e" + base_3 + "a" ;
          pple  = base_1 + base_2 + "e" + base_3 + "ë"
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => pres1 ; P2 => nonExist ; P3 => nonExist } ;
            Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
          } ;
          Past => mkPerfTable pple ;
          Aorist => mkAorTable aor1 ;
          Imperfect => table {
            Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
            Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
          }
        } ;
        Imperative = table { Sg => nonExist ; Pl => nonExist } ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV087"
  } ;

mkV088 : Str -> V ;
mkV088 base =
  case base of {
    "vrokth" => lin V {
      Indicative = table {
        Pres => table {
          Sg => table { P1 => "vrokth" ; P2 => nonExist ; P3 => nonExist } ;
          Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
        } ;
        Past => table {
          Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
          Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
        } ;
        Aorist => table {
          Sg => table { P1 => "m" ; P2 => nonExist ; P3 => nonExist } ;
          Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
        } ;
        Imperfect => table {
          Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
          Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
        }
      } ;
      Imperative = table { Sg => nonExist ; Pl => nonExist } ;
      participle = "vrokthe" ;
      pres_optative = table {
        Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
        Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
      } ;
      perf_optative = table {
        Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
        Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
      } ;
      pres_admirative = table {
        Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
        Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
      } ;
      imperf_admirative = table {
        Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
        Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
      }
    } ;
    _ => error "Can't apply paradigm mkV088"
  } ;

mkV089 : Str -> V ;
mkV089 base =
  case base of {
    base_1 + "ë" + base_2@(?+?) + "as" =>
      let pres1 = base_1 + "ë" + base_2 + "as" ;
          aor1  = base_1 + "i" + base_2 + "a" ;
          pple  = base_1 + "i" + base_2 + "ë"
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => pres1 ; P2 => nonExist ; P3 => nonExist } ;
            Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
          } ;
          Past => mkPerfTable pple ;
          Aorist => mkAorTable aor1 ;
          Imperfect => table {
            Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
            Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
          }
        } ;
        Imperative = table { Sg => nonExist ; Pl => nonExist } ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV089"
  } ;

mkV090 : Str -> V ;
mkV090 base =
  case base of {
    base_1 + base_2@? + "j" =>
      let stem = base_1 + base_2 ;
          aor1  = base_1 + "u" + base_2 + "jta" ;
          pple  = base_1 + "u" + base_2 + "r"
      in lin V {
        Indicative = table {
          Pres => mkPresJ stem ;
          Past => mkPerfTable pple ;
          Aorist => mkAorTable aor1 ;
          Imperfect => mkImperfVowelStem stem
        } ;
        Imperative = mkImperativeVowelStem stem ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV090"
  } ;

mkV091 : Str -> V ;
mkV091 base =
  case base of {
    base_1+"ie"+base_2@? =>
      let
        presStem = base_1+"ie" ;           -- e.g. zie-
        aorStem  = base_1+base_2+"ev" ;    -- e.g. zjev-
        part     = base_1+base_2+"erë" ;
        admStem  = base_1+base_2+"er" ;    -- drop final ë
        optBase  = base_1+base_2+"ef" ;    -- vsh > fsh pattern on -v- aorists
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table {
              P1 => base_1+"ie"+base_2 ;
              P2 => presStem+"n" ;
              P3 => presStem+"n"
            } ;
            Pl => table {
              P1 => presStem+"jmë" ;
              P2 => presStem+"ni" ;
              P3 => presStem+"jnë"
            }
          } ;
          Past => table {  -- present perfect
            Sg => table {
              P1 => "kam"+" "+part ;
              P2 => "ke"+" "+part ;
              P3 => "ka"+" "+part
            } ;
            Pl => table {
              P1 => "kemi"+" "+part ;
              P2 => "keni"+" "+part ;
              P3 => "kanë"+" "+part
            }
          } ;
          Aorist => table { -- past definite
            Sg => table {
              P1 => aorStem+"a" ;
              P2 => aorStem+"e" ;
              P3 => aorStem+"i"
            } ;
            Pl => table {
              P1 => aorStem+"ëm" ;
              P2 => aorStem+"ët" ;
              P3 => aorStem+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table {
              P1 => presStem+"ja" ;
              P2 => presStem+"je" ;
              P3 => presStem+"nte"
            } ;
            Pl => table {
              P1 => presStem+"nim" ;
              P2 => presStem+"nit" ;
              P3 => presStem+"nin"
            }
          }
        } ;

        Imperative = table {
          Sg => base_1+"ie"+base_2 ;
          Pl => presStem+"ni"
        } ;

        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optBase+"sha" ;
            P2 => optBase+"sh" ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optBase+"shim" ;
            P2 => optBase+"shi" ;
            P3 => optBase+"shin"
          }
        } ;

        perf_optative = table { -- paça + participle
          Sg => table {
            P1 => "paça"+" "+part ;
            P2 => "paç"+" "+part ;
            P3 => "pastë"+" "+part
          } ;
          Pl => table {
            P1 => "paçim"+" "+part ;
            P2 => "paçi"+" "+part ;
            P3 => "paçin"+" "+part
          }
        } ;

        pres_admirative = table {
          Sg => table {
            P1 => admStem+"kam" ;
            P2 => admStem+"ke" ;
            P3 => admStem+"ka"
          } ;
          Pl => table {
            P1 => admStem+"kemi" ;
            P2 => admStem+"keni" ;
            P3 => admStem+"kan"
          }
        } ;

        imperf_admirative = table {
          Sg => table {
            P1 => admStem+"kësha" ;
            P2 => admStem+"këshe" ;
            P3 => admStem+"kësh"
          } ;
          Pl => table {
            P1 => admStem+"këshim" ;
            P2 => admStem+"këshit" ;
            P3 => admStem+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV091"
  } ;

mkV092 : Str -> V ;
mkV092 base =
  case base of {
    base_1+"ij" =>
      let
