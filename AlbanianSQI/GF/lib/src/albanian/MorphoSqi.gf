                                 Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                                 Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1 ;
                                           P2 => base_1+"e" ;
                                           P3 => base_1+"i"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"ëm" ;
                                           P2 => base_1+"ët" ;
                                           P3 => base_1+"ën"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+"ja" ;
                                              P2 => base_1+"je" ;
                                              P3 => base_1+"te"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+"nim" ;
                                              P2 => base_1+"nit" ;
                                              P3 => base_1+"nin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1 ;
                       Pl => base_1+"ni"
                     } ;
        participle = base_1+"ur" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => base_1+"sha" ;
                                  P2 => base_1+"sh" ;
                                  P3 => base_1+"të"
                                } ;
                          Pl => table {
                                  P1 => base_1+"shim" ;
                                  P2 => base_1+"shi" ;
                                  P3 => base_1+"shin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table {
                                  P1 => "paça"+" "+(base_1+"ur") ;
                                  P2 => "paç"+" "+(base_1+"ur") ;
                                  P3 => "pastë"+" "+(base_1+"ur")
                                } ;
                          Pl => table {
                                  P1 => "paçim"+" "+(base_1+"ur") ;
                                  P2 => "paçi"+" "+(base_1+"ur") ;
                                  P3 => "paçin"+" "+(base_1+"ur")
                                }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => base_1+"kam" ;
                                    P2 => base_1+"ke" ;
                                    P3 => base_1+"ka"
                                  } ;
                            Pl => table {
                                    P1 => base_1+"kemi" ;
                                    P2 => base_1+"keni" ;
                                    P3 => base_1+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => base_1+"kësha" ;
                                      P2 => base_1+"këshe" ;
                                      P3 => base_1+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => base_1+"këshim" ;
                                      P2 => base_1+"këshit" ;
                                      P3 => base_1+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV078"
  } ;

mkV079 : Str -> V ;
mkV079 base =
