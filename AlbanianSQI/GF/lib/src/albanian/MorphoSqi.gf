      let sgSurf = base_1 + "ë" + base_2 ;
          sgStem = base_1 + base_2 ;
          pl     = sgStem + "e"
      in lin N { s = table {
              Indef => table {
                         Nom => table { Sg => sgSurf ; Pl => pl } ;
                         Acc => table { Sg => sgSurf ; Pl => pl } ;
                         Dat => table { Sg => N54_mascSgIndObl sgStem ; Pl => pl + "ve" } ;
