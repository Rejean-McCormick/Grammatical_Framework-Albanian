mkV085 base =
  case base of {
    base_1 + "j" =>
      let stem = base_1 ;
          aor1 = base_1 + "na" ;
          pple = base_1 + "rë"
      in lin V {
        Indicative = table {
          Pres => mkPresJ stem ;
