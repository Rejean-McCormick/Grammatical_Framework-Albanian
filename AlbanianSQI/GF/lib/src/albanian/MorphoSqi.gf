                       Pl => base_1+"eni"
                     } ;
        participle = base_1+"yrë" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => (base_1+"e")+"fsha" ;
                                  P2 => (base_1+"e")+"fsh" ;
