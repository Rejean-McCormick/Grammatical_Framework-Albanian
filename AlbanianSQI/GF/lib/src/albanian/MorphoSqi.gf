        imperf_admirative = table {
          Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
          Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV028"
  } ;

mkV029 : Str -> V ;
mkV029 base_1 =
  let
    presS : Str = base_1 ;
    aorS  : Str = base_1 ;
    impS  : Str = base_1 ;
    part  : Str = base_1+"tur" ;
    partStem : Str = base_1+"tu" ;
    optBase : Str = aorS ;
    optSh : Str = optBase+"sh" ;
  in lin V {
    Indicative = table {
      Pres => table {
        Sg => table { P1 => presS ; P2 => presS ; P3 => presS } ;
        Pl => table { P1 => presS+"im" ; P2 => presS+"ni" ; P3 => presS+"in" }
      } ;
      Past => table {
        Sg => table { P1 => "kam "+part ; P2 => "ke "+part ; P3 => "ka "+part } ;
        Pl => table { P1 => "kemi "+part ; P2 => "keni "+part ; P3 => "kanë "+part }
      } ;
      Aorist => table {
        Sg => table { P1 => aorS+"a" ; P2 => aorS+"e" ; P3 => aorS+"i" } ;
        Pl => table { P1 => aorS+"ëm" ; P2 => aorS+"ët" ; P3 => aorS+"ën" }
      } ;
      Imperfect => table {
        Sg => table { P1 => impS+"ja" ; P2 => impS+"je" ; P3 => impS+"te" } ;
        Pl => table { P1 => impS+"nim" ; P2 => impS+"nit" ; P3 => impS+"nin" }
      }
    } ;
    Imperative = table { Sg => presS ; Pl => presS+"ni" } ;
    participle = part ;

    pres_optative = table {
      Sg => table { P1 => optSh+"a" ; P2 => optSh ; P3 => optBase+"të" } ;
      Pl => table { P1 => optSh+"im" ; P2 => optSh+"i" ; P3 => optSh+"in" }
    } ;

    perf_optative = table {
      Sg => table { P1 => "paça "+part ; P2 => "paç "+part ; P3 => "pastë "+part } ;
      Pl => table { P1 => "paçim "+part ; P2 => "paçi "+part ; P3 => "paçin "+part }
    } ;

    pres_admirative = table {
      Sg => table { P1 => partStem+"kam" ; P2 => partStem+"ke" ; P3 => partStem+"ka" } ;
      Pl => table { P1 => partStem+"kemi" ; P2 => partStem+"keni" ; P3 => partStem+"kan" }
    } ;

    imperf_admirative = table {
      Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
      Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
    }
  } ;

mkV030 : Str -> V ;
mkV030 base =
  case base of {
    base_1+"i" =>
      let
        presS : Str = base_1+"i" ;
        aorStem : Str = base_1+"ev" ;      -- since 1sg was ...eva
        impS : Str = presS ;
        part : Str = base_1+"inë" ;
        partStem : Str = base_1+"in" ;
        optBase : Str = aorStem ;
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => presS ; P2 => presS ; P3 => presS } ;
            Pl => table { P1 => presS+"më" ; P2 => presS+"ni" ; P3 => presS+"në" }
          } ;
          Past => table {
            Sg => table { P1 => "kam "+part ; P2 => "ke "+part ; P3 => "ka "+part } ;
            Pl => table { P1 => "kemi "+part ; P2 => "keni "+part ; P3 => "kanë "+part }
          } ;
          Aorist => table {
            Sg => table { P1 => aorStem+"a" ; P2 => aorStem+"e" ; P3 => aorStem+"i" } ;
            Pl => table { P1 => aorStem+"ëm" ; P2 => aorStem+"ët" ; P3 => aorStem+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => impS+"ja" ; P2 => impS+"je" ; P3 => impS+"te" } ;
            Pl => table { P1 => impS+"nim" ; P2 => impS+"nit" ; P3 => impS+"nin" }
          }
        } ;
        Imperative = table { Sg => presS ; Pl => presS+"ni" } ;
        participle = part ;

        pres_optative = table {
          Sg => table { P1 => optSh+"a" ; P2 => optSh ; P3 => optBase+"të" } ;
          Pl => table { P1 => optSh+"im" ; P2 => optSh+"i" ; P3 => optSh+"in" }
        } ;

        perf_optative = table {
          Sg => table { P1 => "paça "+part ; P2 => "paç "+part ; P3 => "pastë "+part } ;
          Pl => table { P1 => "paçim "+part ; P2 => "paçi "+part ; P3 => "paçin "+part }
        } ;

        pres_admirative = table {
          Sg => table { P1 => partStem+"kam" ; P2 => partStem+"ke" ; P3 => partStem+"ka" } ;
          Pl => table { P1 => partStem+"kemi" ; P2 => partStem+"keni" ; P3 => partStem+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
          Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV030"
  } ;

mkV031 : Str -> V ;
mkV031 base =
  case base of {
    base_1+"i"+base_2@(?+?)+"em" =>
      let
        stem    = base_1+"i"+base_2 ;        -- non-active stem
        aorRoot = base_1+"o"+base_2 ;        -- given by paradigm
        part    = base_1+"e"+base_2+"ur" ;
        admStem = base_1+"e"+base_2+"u" ;    -- drop final r
        optBase = aorRoot+"f" ;              -- o- aorist -> ofsha type
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table {
              P1 => stem+"em" ;
              P2 => stem+"esh" ;
              P3 => stem+"et"
            } ;
            Pl => table {
              P1 => stem+"emi" ;
              P2 => stem+"eni" ;
              P3 => stem+"en"
            }
          } ;
          Past => table {  -- perfect (non-active)
            Sg => table {
              P1 => "jam"+" "+part ;
              P2 => "je"+" "+part ;
              P3 => "është"+" "+part
            } ;
            Pl => table {
              P1 => "jemi"+" "+part ;
              P2 => "jeni"+" "+part ;
              P3 => "janë"+" "+part
            }
          } ;
          Aorist => table {
            Sg => table {
              P1 => aorRoot+"a" ;
              P2 => aorRoot+"e" ;
              P3 => aorRoot+"i"
            } ;
            Pl => table {
              P1 => aorRoot+"ëm" ;
              P2 => aorRoot+"ët" ;
              P3 => aorRoot+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table {
              P1 => stem+"esha" ;
              P2 => stem+"eshe" ;
              P3 => stem+"ej"
            } ;
            Pl => table {
              P1 => stem+"eshim" ;
              P2 => stem+"eshit" ;
              P3 => stem+"eshin"
            }
          }
        } ;

        Imperative = table {
          Sg => stem+"u" ;
          Pl => stem+"uni"
        } ;

        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optBase+"sha" ;
            P2 => optBase+"sh" ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optBase+"shim" ;
            P2 => optBase+"shi" ;
            P3 => optBase+"shin"
          }
        } ;

        perf_optative = table { -- qof- + participle (non-active)
          Sg => table {
            P1 => "qofsha"+" "+part ;
            P2 => "qofsh"+" "+part ;
            P3 => "qoftë"+" "+part
          } ;
          Pl => table {
            P1 => "qofshim"+" "+part ;
            P2 => "qofshi"+" "+part ;
            P3 => "qofshin"+" "+part
          }
        } ;

        pres_admirative = table {
          Sg => table {
            P1 => admStem+"kam" ;
            P2 => admStem+"ke" ;
            P3 => admStem+"ka"
          } ;
          Pl => table {
            P1 => admStem+"kemi" ;
            P2 => admStem+"keni" ;
            P3 => admStem+"kan"
          }
        } ;

        imperf_admirative = table {
          Sg => table {
            P1 => admStem+"kësha" ;
            P2 => admStem+"këshe" ;
            P3 => admStem+"kësh"
          } ;
          Pl => table {
            P1 => admStem+"këshim" ;
            P2 => admStem+"këshit" ;
            P3 => admStem+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV031"
  } ;

mkV032 : Str -> V ;
mkV032 base =
  case base of {
    base_1+"u"+base_2@?+"j" =>
      let
        presStem = base_1+"u"+base_2 ;       -- active -j class
        aorRoot  = base_1+"ov" ;             -- lov-, punov- type
        part     = base_1+"u"+base_2+"r" ;
        admStem  = base_1+"u"+base_2 ;       -- drop final r
        optBase  = base_1+"of" ;             -- ov -> of
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table {
              P1 => presStem+"j" ;
              P2 => presStem+"n" ;
              P3 => presStem+"n"
            } ;
            Pl => table {
              P1 => presStem+"jmë" ;
              P2 => presStem+"ni" ;
              P3 => presStem+"jnë"
            }
          } ;
          Past => table { -- perfect (active)
            Sg => table {
              P1 => "kam"+" "+part ;
              P2 => "ke"+" "+part ;
              P3 => "ka"+" "+part
            } ;
            Pl => table {
              P1 => "kemi"+" "+part ;
              P2 => "keni"+" "+part ;
              P3 => "kanë"+" "+part
            }
          } ;
          Aorist => table { -- keep P1 as original shape
            Sg => table {
              P1 => base_1+"ov"+base_2 ;
              P2 => aorRoot+"e" ;
              P3 => aorRoot+"i"
            } ;
            Pl => table {
              P1 => aorRoot+"ëm" ;
              P2 => aorRoot+"ët" ;
              P3 => aorRoot+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table {
              P1 => presStem+"ja" ;
              P2 => presStem+"je" ;
              P3 => presStem+"nte"
            } ;
            Pl => table {
              P1 => presStem+"nim" ;
              P2 => presStem+"nit" ;
              P3 => presStem+"nin"
            }
          }
        } ;

        Imperative = table {
          Sg => presStem+"j" ;
          Pl => presStem+"ni"
        } ;

        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optBase+"sha" ;
            P2 => optBase+"sh" ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optBase+"shim" ;
            P2 => optBase+"shi" ;
            P3 => optBase+"shin"
          }
        } ;

        perf_optative = table { -- paça + participle (active)
          Sg => table {
            P1 => "paça"+" "+part ;
            P2 => "paç"+" "+part ;
            P3 => "pastë"+" "+part
          } ;
          Pl => table {
            P1 => "paçim"+" "+part ;
            P2 => "paçi"+" "+part ;
            P3 => "paçin"+" "+part
          }
        } ;

        pres_admirative = table {
          Sg => table {
            P1 => admStem+"kam" ;
            P2 => admStem+"ke" ;
            P3 => admStem+"ka"
          } ;
          Pl => table {
            P1 => admStem+"kemi" ;
            P2 => admStem+"keni" ;
            P3 => admStem+"kan"
          }
        } ;

        imperf_admirative = table {
          Sg => table {
            P1 => admStem+"kësha" ;
            P2 => admStem+"këshe" ;
            P3 => admStem+"kësh"
          } ;
          Pl => table {
            P1 => admStem+"këshim" ;
            P2 => admStem+"këshit" ;
            P3 => admStem+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV032"
  } ;

mkV033 : Str -> V ;
mkV033 base_1 =
  let
