mkN271 : Str -> N ;
mkN271 base =
  case base of {
    base_1+"ë"+base_2@? =>
      let sgInd : Str = base_1+"ë"+base_2 ;
          plInd : Str = base_1+"ë"+base_2 ;   -- keep as invariable plural (as your original)
          sgOblInd : Str = base_1+base_2+"i" ; -- masc indef Dat/Abl = -i
          plDef : Str = plInd+"t" ;
      in lin N
      { s = table {
              Indef => table {
                         Nom => table { Sg => sgInd ; Pl => plInd } ;
                         Acc => table { Sg => sgInd ; Pl => plInd } ;
                         Dat => table { Sg => sgOblInd ; Pl => plInd+"ve" } ;
                         Ablat=> table { Sg => sgOblInd ; Pl => plInd+"sh" }
                       } ;
              Def => table {
                       Nom => table { Sg => base_1+base_2+"i" ;  Pl => plDef } ;
                       Acc => table { Sg => base_1+base_2+"in" ; Pl => plDef } ;
                       Dat => table { Sg => base_1+base_2+"it" ; Pl => plInd+"ve" } ;
                       Ablat=> table { Sg => base_1+base_2+"it" ; Pl => plInd+"ve" }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN271"
  } ;

