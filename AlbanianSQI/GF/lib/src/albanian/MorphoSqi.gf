mkV098 : Str -> V ;
mkV098 base =
  case base of {
    base_1+"at"+base_2@? =>
      let
        presStem = base_1+"at"+base_2 ;
        aorStem  = base_1+"ash" ;          -- assumes -at- > -ash- in past definite stem
        part     = base_1+base_2+"në" ;
        admStem  = base_1+base_2+"n" ;
        optBase  = aorStem ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table {
              P1 => presStem ;
              P2 => presStem ;
              P3 => presStem
            } ;
            Pl => table {
              P1 => presStem+"im" ;
              P2 => presStem+"ni" ;
              P3 => presStem+"in"
            }
          } ;
          Past => table {
            Sg => table {
              P1 => "kam"+" "+part ;
              P2 => "ke"+" "+part ;
              P3 => "ka"+" "+part
            } ;
            Pl => table {
              P1 => "kemi"+" "+part ;
              P2 => "keni"+" "+part ;
              P3 => "kanë"+" "+part
            }
          } ;
          Aorist => table {
            Sg => table {
              P1 => aorStem+"a" ;
              P2 => aorStem+"e" ;
              P3 => aorStem+"i"
            } ;
            Pl => table {
              P1 => aorStem+"ëm" ;
              P2 => aorStem+"ët" ;
              P3 => aorStem+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table {
              P1 => presStem+"ja" ;
              P2 => presStem+"je" ;
              P3 => presStem+"te"
            } ;
            Pl => table {
              P1 => presStem+"nim" ;
              P2 => presStem+"nit" ;
              P3 => presStem+"nin"
            }
          }
        } ;

        Imperative = table {
          Sg => presStem ;
          Pl => presStem+"ni"
        } ;

        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optBase+"sha" ;
            P2 => optBase+"sh" ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optBase+"shim" ;
            P2 => optBase+"shi" ;
            P3 => optBase+"shin"
          }
        } ;

        perf_optative = table {
          Sg => table {
            P1 => "paça"+" "+part ;
            P2 => "paç"+" "+part ;
            P3 => "pastë"+" "+part
          } ;
          Pl => table {
            P1 => "paçim"+" "+part ;
            P2 => "paçi"+" "+part ;
            P3 => "paçin"+" "+part
          }
        } ;

        pres_admirative = table {
          Sg => table {
            P1 => admStem+"kam" ;
            P2 => admStem+"ke" ;
            P3 => admStem+"ka"
          } ;
          Pl => table {
            P1 => admStem+"kemi" ;
            P2 => admStem+"keni" ;
            P3 => admStem+"kan"
          }
        } ;

        imperf_admirative = table {
          Sg => table {
            P1 => admStem+"kësha" ;
            P2 => admStem+"këshe" ;
            P3 => admStem+"kësh"
          } ;
          Pl => table {
            P1 => admStem+"këshim" ;
            P2 => admStem+"këshit" ;
            P3 => admStem+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV098"
  } ;

mkV099 : Str -> V ;
