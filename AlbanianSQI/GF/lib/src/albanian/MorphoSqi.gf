                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN510"
  } ;-- Updated using the standard noun-case endings:
--  Masc: indef Dat/Abl sg = -i/-u; def Acc sg = -n; def Dat/Abl sg = -t; pl oblique = -ve; pl abl.indef = -sh
--  Fem : indef Dat/Abl sg = -e; def Acc sg = -n; def Dat/Abl sg = -s; pl oblique = -ve; pl abl.indef = -sh

