mkV111 : Str -> V ;
mkV111 base_1 =
  lin V
  { Indicative = table {
                   Pres => table {
                             Sg => table {
                                     P1 => base_1+"j" ;
                                     P2 => base_1+"n" ;
                                     P3 => base_1+"n"
                                   } ;
                             Pl => table {
                                     P1 => base_1+"jmë" ;
                                     P2 => base_1+"ni" ;
                                     P3 => base_1+"jnë"
                                   }
                           } ;
                   Past => table {
                             Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                             Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                           } ;
                   Aorist => table {
                               Sg => table {
                                       P1 => base_1+"va" ;
                                       P2 => base_1+"ve" ;
                                       P3 => base_1+"i"
                                     } ;
                               Pl => table {
                                       P1 => base_1+"më" ;
                                       P2 => base_1+"të" ;
                                       P3 => base_1+"në"
                                     }
                             } ;
                   Imperfect => table {
                                  Sg => table {
                                          P1 => base_1+"ja" ;
                                          P2 => base_1+"je" ;
                                          P3 => base_1+"nte"
                                        } ;
                                  Pl => table {
                                          P1 => base_1+"nim" ;
                                          P2 => base_1+"nit" ;
                                          P3 => base_1+"nin"
                                        }
                                }
