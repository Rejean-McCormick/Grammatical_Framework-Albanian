                     Dat => table { Sg => mascSgIndObl base_1 ; Pl => base_1 + "ave" } ;
                     Ablat => table { Sg => mascSgIndObl base_1 ; Pl => base_1 + "ash" }
                   } ;
          Def => table {
                   Nom => table { Sg => mascSgDefNom base_1 ; Pl => base_1 + "at" } ;
