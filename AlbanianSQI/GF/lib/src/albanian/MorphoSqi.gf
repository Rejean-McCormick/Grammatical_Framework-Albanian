  } ;
-- Updated: fill full paradigms (present/aorist/imperfect/imperative/optative/admirative + perfect-as-"Past")
-- Assumptions aligned to standard descriptions:
--  * Active perfect = kam + participle
--  * Non-active (mediopassive) perfect = jam + participle 
--  * Non-active aorist uses clitic "u " + active aorist, but 3SG has no ending: u hap :
--  * Non-active present/imperfect are synthetic (-em/-esh/-et…, -esha/-eshe/-ej…) 
--  * Optative endings: -a, -, -të, -im, -i, -in; 3SG loses sh for -sh/-fsh; -ç -> s in 3SG 
--  * Admirative: short participle + (k)am/ke/ka/kemi/keni/kan; imperfect admirative uses -kësha etc 
--  * Perfect optative: optative of kam (or jam if non-active) + participle 

mkV061 : Str -> V ;
mkV061 base =
  case base of {
    stem+"em" =>
      let part : Str = stem+"ur" ;
          short : Str = <case part of {
            p+"r" => p ;
            p+"ë" => p ;
            _     => part
          } : Str> ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table {
              P1 => stem+"em" ;
              P2 => stem+"esh" ;
              P3 => stem+"et"
            } ;
            Pl => table {
              P1 => stem+"emi" ;
              P2 => stem+"eni" ;
              P3 => stem+"en"
            }
          } ;
          Past => table {   -- perfect mediopassive: jam + participle
            Sg => table {
              P1 => "jam " + part ;
              P2 => "je "  + part ;
              P3 => "është " + part
            } ;
            Pl => table {
              P1 => "jemi " + part ;
              P2 => "jeni " + part ;
              P3 => "janë " + part
            }
          } ;
          Aorist => table { -- mediopassive aorist: u + active aorist; 3sg has no ending
            Sg => table {
              P1 => "u " + stem+"a" ;
              P2 => "u " + stem+"e" ;
              P3 => "u " + stem
            } ;
            Pl => table {
              P1 => "u " + stem+"ëm" ;
              P2 => "u " + stem+"ët" ;
              P3 => "u " + stem+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table {
              P1 => stem+"esha" ;
              P2 => stem+"eshe" ;
              P3 => stem+"ej"
            } ;
            Pl => table {
              P1 => stem+"eshim" ;
              P2 => stem+"eshit" ;
              P3 => stem+"eshin"
            }
          }
        } ;

        Imperative = table { -- mediopassive imperative: -u attached; -ni after it
          Sg => stem+"u" ;
          Pl => stem+"uni"
        } ;

        participle = part ;

        pres_optative = table { -- non-active marker "u " + optative
          Sg => table {
            P1 => "u " + stem+"sha" ;
            P2 => "u " + stem+"sh" ;
            P3 => "u " + stem+"të"
          } ;
          Pl => table {
            P1 => "u " + stem+"shim" ;
            P2 => "u " + stem+"shi" ;
            P3 => "u " + stem+"shin"
          }
        } ;

        perf_optative = table { -- perfect optative (non-active): qof- + participle
          Sg => table {
            P1 => "qofsha " + part ;
            P2 => "qofsh "  + part ;
            P3 => "qoftë "  + part
          } ;
          Pl => table {
            P1 => "qofshim " + part ;
            P2 => "qofshi "  + part ;
            P3 => "qofshin " + part
          }
        } ;

        pres_admirative = table { -- non-active marker "u " + (short participle + kam)
          Sg => table {
            P1 => "u " + short+"kam" ;
            P2 => "u " + short+"ke" ;
            P3 => "u " + short+"ka"
          } ;
          Pl => table {
            P1 => "u " + short+"kemi" ;
            P2 => "u " + short+"keni" ;
            P3 => "u " + short+"kan"
          }
        } ;

        imperf_admirative = table {
          Sg => table {
            P1 => "u " + short+"kësha" ;
            P2 => "u " + short+"këshe" ;
            P3 => "u " + short+"kësh"
          } ;
          Pl => table {
            P1 => "u " + short+"këshim" ;
            P2 => "u " + short+"këshit" ;
            P3 => "u " + short+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV061"
  } ;

mkV062 : Str -> V ;
mkV062 stem =
  let part : Str = stem+"ur" ;
      short : Str = <case part of {
        p+"r" => p ;
        p+"ë" => p ;
        _     => part
      } : Str> ;
      optSuf : Str = <case stem of {
        _+"n"  => "ç" ;
        _+"sh" => "ç" ;
        _      => "sh"
      } : Str> ;
      opt3sg : Str = <case optSuf of {
        "ç" => stem+"stë" ;
        _   => stem+"të"
      } : Str> ;
  in lin V {
    Indicative = table {
      Pres => table {
        Sg => table { P1 => stem ; P2 => stem ; P3 => stem } ;
        Pl => table { P1 => stem+"im" ; P2 => stem+"ni" ; P3 => stem+"in" }
      } ;
      Past => table { -- perfect active: kam + participle
        Sg => table { P1 => "kam " + part ; P2 => "ke " + part ; P3 => "ka " + part } ;
        Pl => table { P1 => "kemi " + part ; P2 => "keni " + part ; P3 => "kanë " + part }
      } ;
      Aorist => table { -- keep your 1sg -ë, extend with regular endings
        Sg => table { P1 => stem+"ë" ; P2 => stem+"e" ; P3 => stem+"i" } ;
        Pl => table { P1 => stem+"ëm" ; P2 => stem+"ët" ; P3 => stem+"ën" }
      } ;
      Imperfect => table {
        Sg => table { P1 => stem+"ja" ; P2 => stem+"je" ; P3 => stem+"te" } ;
        Pl => table { P1 => stem+"nim" ; P2 => stem+"nit" ; P3 => stem+"nin" }
      }
    } ;

    Imperative = table { Sg => stem ; Pl => stem+"ni" } ;

    participle = part ;

    pres_optative = table {
      Sg => table {
        P1 => stem+optSuf+"a" ;
        P2 => stem+optSuf ;
        P3 => opt3sg
      } ;
      Pl => table {
        P1 => stem+optSuf+"im" ;
        P2 => stem+optSuf+"i" ;
        P3 => stem+optSuf+"in"
      }
    } ;

    perf_optative = table {
      Sg => table { P1 => "paça " + part ; P2 => "paç " + part ; P3 => "pastë " + part } ;
      Pl => table { P1 => "paçim " + part ; P2 => "paçi " + part ; P3 => "paçin " + part }
    } ;

    pres_admirative = table {
      Sg => table { P1 => short+"kam" ; P2 => short+"ke" ; P3 => short+"ka" } ;
      Pl => table { P1 => short+"kemi" ; P2 => short+"keni" ; P3 => short+"kan" }
    } ;

    imperf_admirative = table {
      Sg => table { P1 => short+"kësha" ; P2 => short+"këshe" ; P3 => short+"kësh" } ;
      Pl => table { P1 => short+"këshim" ; P2 => short+"këshit" ; P3 => short+"këshin" }
    }
  } ;

mkV063 : Str -> V ;
mkV063 base =
  case base of {
    pfx+"i"+mid@?+"em" =>
      let presStem : Str = pfx+"i"+mid ;
          aorStem  : Str = pfx+"o"+mid+"r" ;
          part     : Str = presStem+"rur" ;
          short    : Str = <case part of {
            p+"r" => p ;
            p+"ë" => p ;
            _     => part
          } : Str> ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => presStem+"em" ; P2 => presStem+"esh" ; P3 => presStem+"et" } ;
            Pl => table { P1 => presStem+"emi" ; P2 => presStem+"eni" ; P3 => presStem+"en" }
          } ;
          Past => table {
            Sg => table { P1 => "jam " + part ; P2 => "je " + part ; P3 => "është " + part } ;
            Pl => table { P1 => "jemi " + part ; P2 => "jeni " + part ; P3 => "janë " + part }
          } ;
          Aorist => table {
            Sg => table {
              P1 => "u " + aorStem+"a" ;
              P2 => "u " + aorStem+"e" ;
              P3 => "u " + aorStem
            } ;
            Pl => table {
              P1 => "u " + aorStem+"ëm" ;
              P2 => "u " + aorStem+"ët" ;
              P3 => "u " + aorStem+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table { P1 => presStem+"esha" ; P2 => presStem+"eshe" ; P3 => presStem+"ej" } ;
            Pl => table { P1 => presStem+"eshim" ; P2 => presStem+"eshit" ; P3 => presStem+"eshin" }
          }
        } ;

        Imperative = table { Sg => presStem+"u" ; Pl => presStem+"uni" } ;

        participle = part ;

        pres_optative = table {
          Sg => table { P1 => "u " + aorStem+"sha" ; P2 => "u " + aorStem+"sh" ; P3 => "u " + aorStem+"të" } ;
          Pl => table { P1 => "u " + aorStem+"shim" ; P2 => "u " + aorStem+"shi" ; P3 => "u " + aorStem+"shin" }
        } ;

        perf_optative = table {
          Sg => table { P1 => "qofsha " + part ; P2 => "qofsh " + part ; P3 => "qoftë " + part } ;
          Pl => table { P1 => "qofshim " + part ; P2 => "qofshi " + part ; P3 => "qofshin " + part }
        } ;

        pres_admirative = table {
          Sg => table { P1 => "u " + short+"kam" ; P2 => "u " + short+"ke" ; P3 => "u " + short+"ka" } ;
          Pl => table { P1 => "u " + short+"kemi" ; P2 => "u " + short+"keni" ; P3 => "u " + short+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => "u " + short+"kësha" ; P2 => "u " + short+"këshe" ; P3 => "u " + short+"kësh" } ;
          Pl => table { P1 => "u " + short+"këshim" ; P2 => "u " + short+"këshit" ; P3 => "u " + short+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV063"
  } ;

mkV064 : Str -> V ;
mkV064 base =
  case base of {
    pfx+"a"+sfx@? =>
      let presStem : Str = pfx+"a"+sfx ;
          aorStem  : Str = pfx+"e"+sfx ;
          part     : Str = aorStem+"ur" ;
          short    : Str = <case part of { p+"r" => p ; p+"ë" => p ; _ => part } : Str> ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => presStem ; P2 => presStem ; P3 => presStem } ;
            Pl => table { P1 => presStem+"im" ; P2 => presStem+"ni" ; P3 => presStem+"in" }
          } ;
          Past => table {
            Sg => table { P1 => "kam " + part ; P2 => "ke " + part ; P3 => "ka " + part } ;
            Pl => table { P1 => "kemi " + part ; P2 => "keni " + part ; P3 => "kanë " + part }
          } ;
          Aorist => table {
            Sg => table { P1 => aorStem+"a" ; P2 => aorStem+"e" ; P3 => aorStem+"i" } ;
            Pl => table { P1 => aorStem+"ëm" ; P2 => aorStem+"ët" ; P3 => aorStem+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => presStem+"ja" ; P2 => presStem+"je" ; P3 => presStem+"te" } ;
            Pl => table { P1 => presStem+"nim" ; P2 => presStem+"nit" ; P3 => presStem+"nin" }
          }
        } ;

        Imperative = table { Sg => presStem ; Pl => presStem+"ni" } ;

        participle = part ;

        pres_optative = table {
          Sg => table { P1 => aorStem+"sha" ; P2 => aorStem+"sh" ; P3 => aorStem+"të" } ;
          Pl => table { P1 => aorStem+"shim" ; P2 => aorStem+"shi" ; P3 => aorStem+"shin" }
        } ;

        perf_optative = table {
          Sg => table { P1 => "paça " + part ; P2 => "paç " + part ; P3 => "pastë " + part } ;
          Pl => table { P1 => "paçim " + part ; P2 => "paçi " + part ; P3 => "paçin " + part }
        } ;

        pres_admirative = table {
          Sg => table { P1 => short+"kam" ; P2 => short+"ke" ; P3 => short+"ka" } ;
          Pl => table { P1 => short+"kemi" ; P2 => short+"keni" ; P3 => short+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => short+"kësha" ; P2 => short+"këshe" ; P3 => short+"kësh" } ;
          Pl => table { P1 => short+"këshim" ; P2 => short+"këshit" ; P3 => short+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV064"
  } ;

