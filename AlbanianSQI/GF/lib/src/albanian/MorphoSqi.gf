  } ;-- Updated: remove "guessed" noun-case endings by using the standard case suffix logic:
--  * Dat/Abl plural: -ve (indef = def) 
--  * Abl plural (indef): -sh 
--  * Masc sg def: -i / -u ; Acc sg def adds -n ; Dat/Abl sg def adds -t 
--  * Fem sg def: -a ; Acc sg def -n (often orthographic -ën) ; Dat/Abl sg def -s 

mkN451 : Str -> N ;
mkN451 base =
  case base of {
    "manxu"+base_1+"anë" => lin N
      { s = table {
              Indef => table {
                         Nom => table {
                                  Sg => "manxu"+base_1+"anë" ;
                                  Pl => "bo"+base_1+"zilokë"
                                } ;
                         Acc => table {
                                  Sg => "manxu"+base_1+"anë" ;
                                  Pl => "bo"+base_1+"zilokë"
                                } ;
                         Dat => table {
                                  -- treat as masc o-stem: indef oblique sg = -u form (like shok → shoku) 
                                  Sg => "bo"+base_1+"ziloku" ;
                                  Pl => "bo"+base_1+"zilokëve"
                                } ;
                         Ablat => table {
                                  Sg => "bo"+base_1+"ziloku" ;
                                  Pl => "bo"+base_1+"zilokësh"
                                }
                       } ;
              Def => table {
                       Nom => table {
                                Sg => "bo"+base_1+"ziloku" ;
                                Pl => "bo"+base_1+"zilokët"
                              } ;
                       Acc => table {
                                Sg => "bo"+base_1+"zilokun" ;
                                Pl => "bo"+base_1+"zilokët"
                              } ;
                       Dat => table {
                                Sg => "bo"+base_1+"zilokut" ;
                                Pl => "bo"+base_1+"zilokëve"
                              } ;
                       Ablat => table {
                                  Sg => "bo"+base_1+"zilokut" ;
                                  Pl => "bo"+base_1+"zilokëve"
                                }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN451"
  } ;

