mkV086 : Str -> V ;
mkV086 base =
  case base of {
    base_1 + "ej" =>
      let stem = base_1 + "e" ;
          aor1 = base_1 + "eva" ;
          pple = base_1 + "uar"
      in lin V {
        Indicative = table {
          Pres => mkPresJ stem ;
          Past => mkPerfTable pple ;
          Aorist => mkAorTable aor1 ;
          Imperfect => mkImperfVowelStem stem
        } ;
