      let
        sg = base_1+"e" ;
        pl = base_1+"e" ;          -- invariant plural
      in lin N {
        s = table {
          Indef => table {
            Nom => table { Sg => sg ; Pl => pl } ;
            Acc => table { Sg => sg ; Pl => pl } ;
            Dat => table { Sg => base_1+"eje" ; Pl => base_1+"eve" } ;
            Ablat => table { Sg => base_1+"eje" ; Pl => base_1+"esh" }
          } ;
          Def => table {
            Nom => table { Sg => base_1+"ja" ; Pl => base_1+"et" } ;
            Acc => table { Sg => base_1+"en" ; Pl => base_1+"et" } ;
            Dat => table { Sg => base_1+"es" ; Pl => base_1+"eve" } ;
