              Def => table {
                       Nom => table { Sg => N54_mascSgDefNom sgStem ; Pl => pl + "t" } ;
                       Acc => table { Sg => N54_mascSgDefAcc sgStem ; Pl => pl + "t" } ;
                       Dat => table { Sg => N54_mascSgDefObl sgStem ; Pl => pl + "ve" } ;
