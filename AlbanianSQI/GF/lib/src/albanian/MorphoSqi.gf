mkV121 : Str -> V ;
mkV121 base =
  case base of {
    base_1+"oj" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"oj" ;
                                         P2 => base_1+"on" ;
                                         P3 => base_1+"on"
                                       } ;
                                 Pl => table {
                                         P1 => base_1+"ojmë" ;
                                         P2 => base_1+"oni" ;
                                         P3 => base_1+"ojnë"
                                       }
                               } ;
                       -- present perfect
                       Past => table {
                                 Sg => table {
                                         P1 => "kam "+base_1+"uar" ;
                                         P2 => "ke "+base_1+"uar" ;
                                         P3 => "ka "+base_1+"uar"
                                       } ;
                                 Pl => table {
                                         P1 => "kemi "+base_1+"uar" ;
                                         P2 => "keni "+base_1+"uar" ;
                                         P3 => "kanë "+base_1+"uar"
                                       }
                               } ;
                       -- past definite
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+"ova" ;
                                           P2 => base_1+"ove" ;
                                           P3 => base_1+"oi"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"uam" ;
                                           P2 => base_1+"uat" ;
                                           P3 => base_1+"uan"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+"oja" ;
                                              P2 => base_1+"oje" ;
                                              P3 => base_1+"onte"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+"onim" ;
                                              P2 => base_1+"onit" ;
                                              P3 => base_1+"onin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"o" ;
                       Pl => base_1+"oni"
                     } ;
        participle = base_1+"uar" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => base_1+"ofsha" ;
                                  P2 => base_1+"ofsh" ;
                                  P3 => base_1+"oftë"
                                } ;
                          Pl => table {
                                  P1 => base_1+"ofshim" ;
                                  P2 => base_1+"ofshi" ;
                                  P3 => base_1+"ofshin"
                                }
                        } ;
        -- perfect optative: paça + participle
        perf_optative = table {
                          Sg => table {
                                  P1 => "paça "+base_1+"uar" ;
                                  P2 => "paç "+base_1+"uar" ;
                                  P3 => "pastë "+base_1+"uar"
                                } ;
                          Pl => table {
                                  P1 => "paçim "+base_1+"uar" ;
                                  P2 => "paçi "+base_1+"uar" ;
                                  P3 => "paçin "+base_1+"uar"
                                }
                        } ;
        -- admirative: participle-stem (punua-) + present/imperfect of kam
        pres_admirative = table {
                            Sg => table {
                                    P1 => base_1+"ua"+"kam" ;
                                    P2 => base_1+"ua"+"ke" ;
                                    P3 => base_1+"ua"+"ka"
                                  } ;
                            Pl => table {
                                    P1 => base_1+"ua"+"kemi" ;
                                    P2 => base_1+"ua"+"keni" ;
                                    P3 => base_1+"ua"+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => base_1+"ua"+"kësha" ;
                                      P2 => base_1+"ua"+"këshe" ;
                                      P3 => base_1+"ua"+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => base_1+"ua"+"këshim" ;
                                      P2 => base_1+"ua"+"këshit" ;
                                      P3 => base_1+"ua"+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV121"
  } ;

