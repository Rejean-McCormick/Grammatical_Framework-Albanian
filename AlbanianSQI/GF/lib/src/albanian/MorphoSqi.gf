resource MorphoSqi = open CatSqi, ResSqi, Predef, Prelude in {

oper

mkN001 : Str -> N ;
mkN001 base_1 =
  let plInd : Str = base_1+"e" ;
      plDef : Str = plInd+"t" ;
  in lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1 ;   Pl => plInd } ;
                     Acc   => table { Sg => base_1 ;   Pl => plInd } ;
                     Dat   => table { Sg => base_1+"i" ; Pl => plInd+"ve" } ;  -- -eve
                     Ablat => table { Sg => base_1+"i" ; Pl => plInd+"sh" }   -- -esh
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"i" ;  Pl => plDef } ;
                   Acc   => table { Sg => base_1+"in" ; Pl => plDef } ;
                   Dat   => table { Sg => base_1+"it" ; Pl => plInd+"ve" } ;
                   Ablat => table { Sg => base_1+"it" ; Pl => plInd+"ve" }
                 }
        } ;
    g = Masc
  } ;

mkN002 : Str -> N ;
mkN002 base_1 =
