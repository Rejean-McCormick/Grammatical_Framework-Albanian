                         Acc => table { Sg => sg ; Pl => pl } ;
                         Dat => table { Sg => mascSgIndObl sg ; Pl => pl + "ve" } ;
                         Ablat => table { Sg => mascSgIndObl sg ; Pl => pl + "sh" }
                       } ;
              Def => table {
                       Nom => table { Sg => mascSgDefNom sg ; Pl => pl + "t" } ;
                       Acc => table { Sg => mascSgDefAcc sg ; Pl => pl + "t" } ;
                       Dat => table { Sg => mascSgDefObl sg ; Pl => pl + "ve" } ;
