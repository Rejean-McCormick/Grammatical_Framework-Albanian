oper
  -- masc: oblique sg indefinite is -u after velars, -i elsewhere
  mascSgIndObl : Str -> Str = \st ->
    <case st of {
      _ + "k" => st + "u" ;
      _ + "g" => st + "u" ;
      _ + "h" => st + "u" ;
      _       => st + "i"
    } : Str> ;

  -- masc: def nom sg is -u after velars, -i elsewhere
  mascSgDefNom : Str -> Str = \st ->
    <case st of {
      _ + "k" => st + "u" ;
      _ + "g" => st + "u" ;
      _ + "h" => st + "u" ;
      _       => st + "i"
    } : Str> ;

  mascSgDefAcc : Str -> Str = \st -> mascSgDefNom st + "n" ;
  mascSgDefObl : Str -> Str = \st -> mascSgDefNom st + "t" ;

  -- fem schwa-final helpers
  femIndObl_schwa : Str -> Str = \base ->
    <case base of { st + "ë" => st + "e" ; _ => base + "e" } : Str> ;

  femDefNom_schwa : Str -> Str = \base ->
    <case base of { st + "ë" => st + "a" ; _ => base + "a" } : Str> ;

  femDefAcc_schwa : Str -> Str = \base ->
    <case base of { st + "ë" => st + "ën" ; _ => base + "n" } : Str> ;

  femDefObl_schwa : Str -> Str = \base ->
    <case base of { st + "ë" => st + "ës" ; _ => base + "s" } : Str> ;

mkN281 : Str -> N ;
mkN281 base_1 =
  let pl = base_1 + "ërinj" in
  lin N
  { s = table {
          Indef => table {
                     Nom => table { Sg => base_1 ; Pl => pl } ;
                     Acc => table { Sg => base_1 ; Pl => pl } ;
                     Dat => table { Sg => mascSgIndObl base_1 ; Pl => pl + "ve" } ;
                     Ablat => table { Sg => mascSgIndObl base_1 ; Pl => pl + "sh" }
                   } ;
          Def => table {
                   Nom => table { Sg => mascSgDefNom base_1 ; Pl => base_1 + "ërinjtë" } ;
                   Acc => table { Sg => mascSgDefAcc base_1 ; Pl => base_1 + "ërinjtë" } ;
                   Dat => table { Sg => mascSgDefObl base_1 ; Pl => pl + "ve" } ;
                   Ablat => table { Sg => mascSgDefObl base_1 ; Pl => pl + "ve" }
                 }
        } ;
    g = Masc
  } ;

