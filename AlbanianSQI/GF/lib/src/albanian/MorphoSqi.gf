mkV066 : Str -> V ;
mkV066 base =
  case base of {
    "hë"+x+"a" =>
      let aorStem : Str = "hë"+x ;      -- hëngr-
          part    : Str = x+"ënë" ;     -- ngrënë
          short   : Str = <case part of { p+"ë" => p ; p+"r" => p ; _ => part } : Str> ; -- ngrën
          optStem : Str = short+"ç" ;   -- ngrënç-
      in lin V {
        Indicative = table {
          Pres => table {               -- ha paradigm
            Sg => table { P1 => "ha" ; P2 => "ha" ; P3 => "ha" } ;
            Pl => table { P1 => "hamë" ; P2 => "hani" ; P3 => "hanë" }
          } ;
          Past => table {               -- kam ngrënë
            Sg => table { P1 => "kam " + part ; P2 => "ke " + part ; P3 => "ka " + part } ;
            Pl => table { P1 => "kemi " + part ; P2 => "keni " + part ; P3 => "kanë " + part }
          } ;
          Aorist => table {             -- hëngra, hëngre, hëngri, ...
            Sg => table { P1 => aorStem+"a" ; P2 => aorStem+"e" ; P3 => aorStem+"i" } ;
            Pl => table { P1 => aorStem+"ëm" ; P2 => aorStem+"ët" ; P3 => aorStem+"ën" }
          } ;
          Imperfect => table {          -- haja, haje, hante, hanim, hanit, hanin
            Sg => table { P1 => "haja" ; P2 => "haje" ; P3 => "hante" } ;
            Pl => table { P1 => "hanim" ; P2 => "hanit" ; P3 => "hanin" }
          }
        } ;

        Imperative = table { Sg => "ha" ; Pl => "hani" } ;

        participle = part ;

        pres_optative = table {         -- ngrënça ... (approx. 3sg uses -s-)
          Sg => table {
            P1 => optStem+"a" ;
            P2 => optStem ;
            P3 => short+"stë"
          } ;
          Pl => table {
            P1 => optStem+"im" ;
            P2 => optStem+"i" ;
            P3 => optStem+"in"
          }
        } ;

        perf_optative = table {
          Sg => table { P1 => "paça " + part ; P2 => "paç " + part ; P3 => "pastë " + part } ;
          Pl => table { P1 => "paçim " + part ; P2 => "paçi " + part ; P3 => "paçin " + part }
        } ;

        pres_admirative = table {
          Sg => table { P1 => short+"kam" ; P2 => short+"ke" ; P3 => short+"ka" } ;
          Pl => table { P1 => short+"kemi" ; P2 => short+"keni" ; P3 => short+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => short+"kësha" ; P2 => short+"këshe" ; P3 => short+"kësh" } ;
          Pl => table { P1 => short+"këshim" ; P2 => short+"këshit" ; P3 => short+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV066"
  } ;

