          plDef = pl + "të"
      in lin N { s = table {
              Indef => table {
                         Nom => table { Sg => sg ; Pl => pl } ;
                         Acc => table { Sg => sg ; Pl => pl } ;
                         Dat => table { Sg => N53_mascSgIndObl sg ; Pl => pl + "ve" } ;
                         Ablat => table { Sg => N53_mascSgIndObl sg ; Pl => pl + "sh" }
                       } ;
              Def => table {
                       Nom => table { Sg => N53_mascSgDefNom sg ; Pl => plDef } ;
                       Acc => table { Sg => N53_mascSgDefAcc sg ; Pl => plDef } ;
                       Dat => table { Sg => N53_mascSgDefObl sg ; Pl => pl + "ve" } ;
                       Ablat => table { Sg => N53_mascSgDefObl sg ; Pl => pl + "ve" }
                     }
            } ;
