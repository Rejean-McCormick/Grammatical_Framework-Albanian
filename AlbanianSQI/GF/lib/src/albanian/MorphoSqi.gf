mkV080 : Str -> V ;
mkV080 base =
  case base of {
    base_1+"s" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"s" ;
                                         P2 => base_1+"t" ;
                                         P3 => base_1+"t"
                                       } ;
                                 Pl => table {
                                         P1 => (base_1+"s")+"im" ;
                                         P2 => (base_1+"s")+"ni" ;
                                         P3 => (base_1+"s")+"in"
                                       }
                               } ;
                       Past => table {
                                 Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                                 Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+"ta" ;
                                           P2 => base_1+"te" ;
                                           P3 => base_1+"ti"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"tëm" ;
                                           P2 => base_1+"tët" ;
                                           P3 => base_1+"tën"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => (base_1+"t")+"ja" ;
                                              P2 => (base_1+"t")+"je" ;
                                              P3 => (base_1+"t")+"te"
                                            } ;
                                      Pl => table {
                                              P1 => (base_1+"t")+"nim" ;
                                              P2 => (base_1+"t")+"nit" ;
                                              P3 => (base_1+"t")+"nin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"t" ;
                       Pl => (base_1+"t")+"ni"
                     } ;
        participle = base_1+"tur" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => (base_1+"t")+"sha" ;
                                  P2 => (base_1+"t")+"sh" ;
                                  P3 => (base_1+"t")+"të"
                                } ;
                          Pl => table {
                                  P1 => (base_1+"t")+"shim" ;
                                  P2 => (base_1+"t")+"shi" ;
                                  P3 => (base_1+"t")+"shin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table {
                                  P1 => "paça"+" "+(base_1+"tur") ;
                                  P2 => "paç"+" "+(base_1+"tur") ;
                                  P3 => "pastë"+" "+(base_1+"tur")
                                } ;
                          Pl => table {
                                  P1 => "paçim"+" "+(base_1+"tur") ;
                                  P2 => "paçi"+" "+(base_1+"tur") ;
                                  P3 => "paçin"+" "+(base_1+"tur")
                                }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => (base_1+"t")+"kam" ;
                                    P2 => (base_1+"t")+"ke" ;
                                    P3 => (base_1+"t")+"ka"
                                  } ;
                            Pl => table {
                                    P1 => (base_1+"t")+"kemi" ;
                                    P2 => (base_1+"t")+"keni" ;
                                    P3 => (base_1+"t")+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => (base_1+"t")+"kësha" ;
                                      P2 => (base_1+"t")+"këshe" ;
                                      P3 => (base_1+"t")+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => (base_1+"t")+"këshim" ;
                                      P2 => (base_1+"t")+"këshit" ;
                                      P3 => (base_1+"t")+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV080"
  } ;

oper
  -- helpers

  removeFinalA : Str -> Str = \s ->
    <case s of { st + "a" => st ; _ => s } : Str> ;

  -- 3sg aorist is -u after velars or i/a/e; else -i
  aor3sg : Str -> Str = \st ->
    <case st of {
      _ + "k" => st + "u" ;
      _ + "g" => st + "u" ;
      _ + "h" => st + "u" ;
      _ + "i" => st + "u" ;
      _ + "a" => st + "u" ;
      _ + "e" => st + "u" ;
      _ => st + "i"
    } : Str> ;
  -- KEEP: only helpers that do not exist earlier (canonical block)

  -- For bases like ...e (mkV083): treat as vowel-stem without explicit -j in 1sg.
  mkPresE : Str -> (Number => (Person => Str)) = \baseE ->
    table {
      Sg => table { P1 => baseE ; P2 => baseE + "n" ; P3 => baseE + "n" } ;
      Pl => table { P1 => baseE + "jmë" ; P2 => baseE + "ni" ; P3 => baseE + "jnë" }
    } ;

  mkImperfVowelStem : Str -> (Number => (Person => Str)) = \stem ->
    table {
      Sg => table { P1 => stem + "ja" ; P2 => stem + "je" ; P3 => stem + "nte" } ;
      Pl => table { P1 => stem + "nim" ; P2 => stem + "nit" ; P3 => stem + "nin" }
    } ;

  mkImperativeVowelStem : Str -> (Number => Str) = \stem ->
    table {
      Sg => <case stem of { _ + "o" => stem ; _ + "e" => stem ; _ => stem + "j" } : Str> ;
      Pl => stem + "ni"
    } ;
-- updated paradigms

mkV081 : Str -> V ;
mkV081 base =
  case base of {
    base_1 + "j" =>
      let stem = base_1 ;
          pple = base_1 + "va" ;            -- kept as you had it
          aor1 = base_1 + "va"              -- used to complete the aorist table
      in lin V {
        Indicative = table {
          Pres => mkPresJ stem ;
          Past => mkPerfTable pple ;
          Aorist => mkAorTable aor1 ;
          Imperfect => mkImperfVowelStem stem
        } ;
        Imperative = mkImperativeVowelStem stem ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV081"
  } ;

mkV082 : Str -> V ;
mkV082 base =
  case base of {
    base_1 + base_2@? + "j" =>
      let stem = base_1 + base_2 ;
          aor1 = stem + "jta" ;             -- FIX: jti -> jta
          pple = base_1 + "y" + base_2 + "r"
      in lin V {
        Indicative = table {
          Pres => mkPresJ stem ;
          Past => mkPerfTable pple ;
          Aorist => mkAorTable aor1 ;
          Imperfect => mkImperfVowelStem stem
        } ;
        Imperative = mkImperativeVowelStem stem ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV082"
  } ;

mkV083 : Str -> V ;
mkV083 base =
  case base of {
    base_1 + "e" =>
      let baseE = base_1 + "e" ;
          stem  = baseE ;                   -- vowel-stem for imperfect/imperative heuristics
          aor1  = base_1 + "va" ;
          pple  = base_1 + "rë"
      in lin V {
        Indicative = table {
          Pres => mkPresE baseE ;
          Past => mkPerfTable pple ;
          Aorist => mkAorTable aor1 ;
          Imperfect => mkImperfVowelStem stem
        } ;
        Imperative = mkImperativeVowelStem stem ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV083"
  } ;

mkV084 : Str -> V ;
mkV084 base =
  case base of {
    "e" + base_1 + "a" =>
      let aor1 = "e" + base_1 + "a" ;
          pple = "a" + base_1 + "ur"
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => aor1 ; P2 => nonExist ; P3 => nonExist } ;
            Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
          } ;
          Past => mkPerfTable pple ;
          Aorist => mkAorTable aor1 ;
          Imperfect => table {
            Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
            Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
          }
        } ;
        Imperative = table { Sg => nonExist ; Pl => nonExist } ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV084"
  } ;

