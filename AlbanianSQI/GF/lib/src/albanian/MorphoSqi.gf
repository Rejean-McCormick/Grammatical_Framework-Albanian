oper
  N53_mascSgIndObl : Str -> Str = \st ->
    <case st of {
      _ + "k" => st + "u" ;
      _ + "g" => st + "u" ;
      _ + "h" => st + "u" ;
      _       => st + "i"
    } : Str> ;

  N53_mascSgDefNom : Str -> Str = \st ->
    <case st of {
      _ + "k" => st + "u" ;
      _ + "g" => st + "u" ;
      _ + "h" => st + "u" ;
      _       => st + "i"
    } : Str> ;

  N53_mascSgDefAcc : Str -> Str = \st -> N53_mascSgDefNom st + "n" ;
  N53_mascSgDefObl : Str -> Str = \st -> N53_mascSgDefNom st + "t" ;

  -- fem -e: def.nom.sg = -ja, but after j: -a
  N53_femDefNom_E : Str -> Str = \st ->
    <case st of { _ + "j" => st + "a" ; _ => st + "ja" } : Str> ;

mkN531 : Str -> N ;
mkN531 base_1 =
  let sg = base_1 ;
      pl = base_1 + "u" ;
      defSg = base_1 + "je" ;
      defPl = base_1 + "jet"
  in lin N
  { s = table {
          Indef => table {
                     Nom => table { Sg => sg ; Pl => pl } ;
                     Acc => table { Sg => sg ; Pl => pl } ;
                     Dat => table { Sg => N53_mascSgIndObl sg ; Pl => pl + "ve" } ;
                     Ablat => table { Sg => N53_mascSgIndObl sg ; Pl => pl + "sh" }
                   } ;
          Def => table {
                   Nom => table { Sg => defSg ; Pl => defPl } ;
                   Acc => table { Sg => defSg + "n" ; Pl => defPl } ;
                   Dat => table { Sg => defSg + "t" ; Pl => pl + "ve" } ;
                   Ablat => table { Sg => defSg + "t" ; Pl => pl + "ve" }
                 }
        } ;
    g = Masc
  } ;

mkN532 : Str -> N ;
