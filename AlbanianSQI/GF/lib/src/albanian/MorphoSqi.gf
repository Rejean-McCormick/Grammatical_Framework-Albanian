                         Dat => table { Sg => st + "e" ; Pl => pl + "ve" } ;
                         Ablat => table { Sg => st + "e" ; Pl => pl + "sh" }
                       } ;
              Def => table {
                       Nom => table { Sg => st + "a"  ; Pl => pl + "t" } ;
                       Acc => table { Sg => st + "ën" ; Pl => pl + "t" } ;
