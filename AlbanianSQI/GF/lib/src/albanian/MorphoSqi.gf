        P2 => "paç"+" "+part ;
        P3 => "pastë"+" "+part
      } ;
      Pl => table {
        P1 => "paçim"+" "+part ;
        P2 => "paçi"+" "+part ;
        P3 => "paçin"+" "+part
      }
    } ;

    pres_admirative = table {
      Sg => table {
        P1 => admStem+"kam" ;
        P2 => admStem+"ke" ;
        P3 => admStem+"ka"
      } ;
      Pl => table {
        P1 => admStem+"kemi" ;
        P2 => admStem+"keni" ;
        P3 => admStem+"kan"
      }
    } ;

    imperf_admirative = table {
      Sg => table {
        P1 => admStem+"kësha" ;
        P2 => admStem+"këshe" ;
        P3 => admStem+"kësh"
      } ;
      Pl => table {
        P1 => admStem+"këshim" ;
        P2 => admStem+"këshit" ;
        P3 => admStem+"këshin"
      }
    }
  } ;

