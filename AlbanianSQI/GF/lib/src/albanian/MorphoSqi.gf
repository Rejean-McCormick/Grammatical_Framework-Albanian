mkV110 : Str -> V ;
mkV110 base =
  case base of {
    base_1+"ih"+base_2@?+"m" =>
      let
        pres1   = base_1+"ih"+base_2+"m" ;
        aorStem = base_1+base_2+"v" ;
        pple    = base_1+"y"+base_2+"r" ;
        shortP  = base_1+"y"+base_2 ;
      in lin V {
        Indicative = table {
          Pres      => mkPers pres1 nonExist nonExist nonExist nonExist nonExist ;
          Past      => mkPerf pple ;
          Aorist    => mkAorCons aorStem ;
          Imperfect => mkPers nonExist nonExist nonExist nonExist nonExist nonExist
        } ;
        Imperative = table { Sg => nonExist ; Pl => nonExist } ;
        participle = pple ;
        pres_optative = mkPers nonExist nonExist nonExist nonExist nonExist nonExist ;
        perf_optative = mkPerfOpt2 pple ;
        pres_admirative = mkAdmPresShort shortP ;
        imperf_admirative = mkAdmImpf shortP
      } ;
    _ => error "Can't apply paradigm mkV110"
