mkN006 : Str -> N ;
mkN006 base =
  case base of {
    base_1+"ll" =>
      let sg : Str = base_1+"ll" ;
          sgDef : Str = base_1+"lli" ;
          pl : Str = base_1+"je" ;
          plDef : Str = base_1+"jet" ;
      in lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => sg ;    Pl => pl } ;
                         Acc   => table { Sg => sg ;    Pl => pl } ;
                         Dat   => table { Sg => sgDef ; Pl => base_1+"jeve" } ;
                         Ablat => table { Sg => sgDef ; Pl => base_1+"jesh" }
                       } ;
              Def => table {
                       Nom   => table { Sg => sgDef ;      Pl => plDef } ;
                       Acc   => table { Sg => base_1+"llin" ; Pl => plDef } ;
                       Dat   => table { Sg => base_1+"llit" ; Pl => base_1+"jeve" } ;
                       Ablat => table { Sg => base_1+"llit" ; Pl => base_1+"jeve" }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN006"
  } ;

