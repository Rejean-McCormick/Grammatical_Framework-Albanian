          Aorist => table {
            Sg => table {
              P1 => aorRoot+"a" ;
              P2 => aorRoot+"e" ;
              P3 => aorRoot+"i"
            } ;
            Pl => table {
              P1 => aorRoot+"ëm" ;
              P2 => aorRoot+"ët" ;
              P3 => aorRoot+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table {
              P1 => presStem+"ja" ;
              P2 => presStem+"je" ;
              P3 => presStem+"te"
            } ;
            Pl => table {
              P1 => presStem+"nim" ;
              P2 => presStem+"nit" ;
              P3 => presStem+"nin"
            }
          }
        } ;

        Imperative = table {
          Sg => presStem ;
          Pl => presStem+"ni"
        } ;

        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optBase+"sha" ;
            P2 => optBase+"sh" ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optBase+"shim" ;
            P2 => optBase+"shi" ;
            P3 => optBase+"shin"
          }
        } ;

        perf_optative = table {
          Sg => table {
            P1 => "paça"+" "+part ;
            P2 => "paç"+" "+part ;
            P3 => "pastë"+" "+part
          } ;
          Pl => table {
            P1 => "paçim"+" "+part ;
            P2 => "paçi"+" "+part ;
            P3 => "paçin"+" "+part
          }
        } ;

        pres_admirative = table {
          Sg => table {
            P1 => admStem+"kam" ;
            P2 => admStem+"ke" ;
            P3 => admStem+"ka"
          } ;
          Pl => table {
            P1 => admStem+"kemi" ;
            P2 => admStem+"keni" ;
            P3 => admStem+"kan"
          }
        } ;

        imperf_admirative = table {
          Sg => table {
            P1 => admStem+"kësha" ;
            P2 => admStem+"këshe" ;
            P3 => admStem+"kësh"
          } ;
          Pl => table {
            P1 => admStem+"këshim" ;
            P2 => admStem+"këshit" ;
            P3 => admStem+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV036"
  } ;

mkV037 : Str -> V ;
mkV037 base =
  case base of {
    base_1+"sem" =>
      let
        stem    = base_1+"s" ;        -- non-active stem (qasem-type)
        aorRoot = base_1+"t" ;
        part    = base_1+"tur" ;
        admStem = base_1+"tu" ;       -- drop r
        optBase = aorRoot             -- -t- optative (…tsha)
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table {
              P1 => base_1+"sem" ;
              P2 => stem+"esh" ;
              P3 => stem+"et"
            } ;
            Pl => table {
              P1 => stem+"emi" ;
              P2 => stem+"eni" ;
              P3 => stem+"en"
            }
          } ;
          Past => table { -- perfect (non-active)
            Sg => table {
              P1 => "jam"+" "+part ;
              P2 => "je"+" "+part ;
              P3 => "është"+" "+part
            } ;
            Pl => table {
              P1 => "jemi"+" "+part ;
              P2 => "jeni"+" "+part ;
              P3 => "janë"+" "+part
            }
          } ;
          Aorist => table {
            Sg => table {
              P1 => base_1+"ta" ;
              P2 => aorRoot+"e" ;
              P3 => aorRoot+"i"
            } ;
            Pl => table {
              P1 => aorRoot+"ëm" ;
              P2 => aorRoot+"ët" ;
              P3 => aorRoot+"ën"
            }
          } ;
          Imperfect => table { -- non-active imperfect
            Sg => table {
              P1 => stem+"esha" ;
              P2 => stem+"eshe" ;
              P3 => stem+"ej"
            } ;
            Pl => table {
              P1 => stem+"eshim" ;
              P2 => stem+"eshit" ;
              P3 => stem+"eshin"
            }
          }
        } ;

        Imperative = table {
          Sg => stem+"u" ;
          Pl => stem+"uni"
        } ;

        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optBase+"sha" ;
            P2 => optBase+"sh" ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optBase+"shim" ;
            P2 => optBase+"shi" ;
            P3 => optBase+"shin"
          }
        } ;

        perf_optative = table { -- qof- + participle
          Sg => table {
            P1 => "qofsha"+" "+part ;
            P2 => "qofsh"+" "+part ;
            P3 => "qoftë"+" "+part
          } ;
          Pl => table {
            P1 => "qofshim"+" "+part ;
            P2 => "qofshi"+" "+part ;
            P3 => "qofshin"+" "+part
          }
        } ;

        pres_admirative = table {
          Sg => table {
            P1 => admStem+"kam" ;
            P2 => admStem+"ke" ;
            P3 => admStem+"ka"
          } ;
          Pl => table {
            P1 => admStem+"kemi" ;
            P2 => admStem+"keni" ;
            P3 => admStem+"kan"
          }
        } ;

        imperf_admirative = table {
          Sg => table {
            P1 => admStem+"kësha" ;
            P2 => admStem+"këshe" ;
            P3 => admStem+"kësh"
          } ;
          Pl => table {
            P1 => admStem+"këshim" ;
            P2 => admStem+"këshit" ;
            P3 => admStem+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV037"
  } ;

