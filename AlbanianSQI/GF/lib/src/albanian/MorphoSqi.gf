oper
  -- plural definite: after vowel -> +t ; after consonant -> +të
  addPlDef : Str -> Str = \pl ->
    <case pl of {
      _+"a" => pl+"t" ;
      _+"e" => pl+"t" ;
      _+"ë" => pl+"t" ;
      _+"i" => pl+"t" ;
      _+"o" => pl+"t" ;
      _+"u" => pl+"t" ;
      _+"y" => pl+"t" ;
      _ => pl+"të"
    } : Str> ;

