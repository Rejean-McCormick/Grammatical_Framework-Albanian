              P3 => presStem+"nte"
            } ;
            Pl => table {
              P1 => presStem+"nim" ;
              P2 => presStem+"nit" ;
              P3 => presStem+"nin"
            }
          }
        } ;

        Imperative = table {
          Sg => base_1+"ij" ;
          Pl => presStem+"ni"
        } ;

        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optBase+"sha" ;
            P2 => optBase+"sh" ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optBase+"shim" ;
            P2 => optBase+"shi" ;
            P3 => optBase+"shin"
          }
        } ;

        perf_optative = table {
