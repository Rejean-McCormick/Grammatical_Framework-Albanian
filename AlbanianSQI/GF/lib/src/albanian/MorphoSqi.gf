                     Acc   => table { Sg => base_1 ;     Pl => base_1+"e" } ;
                     Dat   => table { Sg => base_1+"i" ; Pl => base_1+"eve" } ;
                     Ablat => table { Sg => base_1+"i" ; Pl => base_1+"esh" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"i" ;  Pl => base_1+"et" } ;
                   Acc   => table { Sg => base_1+"in" ; Pl => base_1+"et" } ;
                   Dat   => table { Sg => base_1+"it" ; Pl => base_1+"eve" } ;
                   Ablat => table { Sg => base_1+"it" ; Pl => base_1+"eve" }
                 }
        } ;
