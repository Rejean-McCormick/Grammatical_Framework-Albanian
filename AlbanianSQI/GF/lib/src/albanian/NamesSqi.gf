resource NamesSqi = open CatSqi, ParadigmsSqi in {

oper
  john_PN, mary_PN : PN ;
  tirana_PN, paris_PN, rome_PN, london_PN : PN ;
  albania_PN : PN ;

  john_PN    = mkPN "Gjon" ;
  mary_PN    = mkPN "Mari" ;

  tirana_PN  = mkPN "Tiranë" ;
  paris_PN   = mkPN "Paris" ;
  rome_PN    = mkPN "Romë" ;
  london_PN  = mkPN "Londër" ;

  albania_PN = mkPN "Shqipëri" ;

}