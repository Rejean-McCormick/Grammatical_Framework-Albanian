  } ;

mkN008 : Str -> N ;
mkN008 base_1 =
  let plInd : Str = base_1 ;
      plDef : Str = base_1+"të" ;
  in lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1 ;       Pl => plInd } ;
                     Acc   => table { Sg => base_1 ;       Pl => plInd } ;
                     Dat   => table { Sg => base_1+"jeje" ; Pl => base_1+"ve" } ;
                     Ablat => table { Sg => base_1+"jeje" ; Pl => base_1+"sh" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"ja" ;   Pl => plDef } ;
                   Acc   => table { Sg => base_1+"në" ;   Pl => plDef } ;
                   Dat   => table { Sg => base_1+"së" ;   Pl => base_1+"ve" } ;
                   Ablat => table { Sg => base_1+"së" ;   Pl => base_1+"ve" }
                 }
        } ;
    g = Fem
  } ;

mkN009 : Str -> N ;
mkN009 base_1 =
  lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1 ;     Pl => base_1+"a" } ;
                     Acc   => table { Sg => base_1 ;     Pl => base_1+"a" } ;
                     Dat   => table { Sg => base_1+"e" ; Pl => base_1+"ave" } ;
                     Ablat => table { Sg => base_1+"e" ; Pl => base_1+"ash" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"a" ;  Pl => base_1+"at" } ;
                   Acc   => table { Sg => base_1+"ën" ; Pl => base_1+"at" } ;
                   Dat   => table { Sg => base_1+"ës" ; Pl => base_1+"ave" } ;
                   Ablat => table { Sg => base_1+"ës" ; Pl => base_1+"ave" }
                 }
        } ;
    g = Fem
  } ;

