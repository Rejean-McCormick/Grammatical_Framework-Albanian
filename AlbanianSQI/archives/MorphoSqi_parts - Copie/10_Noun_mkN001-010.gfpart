mkN005 : Str -> N ;
mkN005 base_1 =
  let plInd : Str = base_1+"e" ;
      plDef : Str = base_1+"et" ;
  in lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1 ;     Pl => plInd } ;
                     Acc   => table { Sg => base_1 ;     Pl => plInd } ;
                     Dat   => table { Sg => base_1+"i" ; Pl => base_1+"eve" } ;
                     Ablat => table { Sg => base_1+"i" ; Pl => base_1+"esh" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"i" ;  Pl => plDef } ;
                   Acc   => table { Sg => base_1+"in" ; Pl => plDef } ;
                   Dat   => table { Sg => base_1+"it" ; Pl => base_1+"eve" } ;
                   Ablat => table { Sg => base_1+"it" ; Pl => base_1+"eve" }
                 }
        } ;
