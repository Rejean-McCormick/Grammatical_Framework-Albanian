                   Acc   => table { Sg => base_1+"un" ;  Pl => base_1+"njtë" } ;
                   Dat   => table { Sg => base_1+"ut" ;  Pl => base_1+"njve" } ;
                   Ablat => table { Sg => base_1+"ut" ;  Pl => base_1+"njve" }
                 }
        } ;
