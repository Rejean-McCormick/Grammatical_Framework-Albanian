mkN174 : Str -> N ;
mkN174 base =
  case base of {
    base_1+"e"+base_2@(?+?+?)+"e" => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"e"+base_2+"e" ;  Pl => nonExist } ;
                         Acc   => table { Sg => base_1+"e"+base_2+"e" ;  Pl => nonExist } ;
                         Dat   => table { Sg => base_1+"e"+base_2+"ei" ; Pl => nonExist } ;
                         Ablat => table { Sg => base_1+"e"+base_2+"ei" ; Pl => nonExist }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+"é"+base_2+"u" ;   Pl => nonExist } ;
                       Acc   => table { Sg => base_1+"é"+base_2+"un" ;  Pl => nonExist } ;
                       Dat   => table { Sg => base_1+"é"+base_2+"ut" ;  Pl => nonExist } ;
                       Ablat => table { Sg => base_1+"é"+base_2+"ut" ;  Pl => nonExist }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN174"
  } ;

