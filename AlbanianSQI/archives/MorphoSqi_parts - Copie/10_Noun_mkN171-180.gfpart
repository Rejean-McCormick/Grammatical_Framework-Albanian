                     Dat   => table { Sg => base_1+"e" ; Pl => base_1+"ve" } ;
                     Ablat => table { Sg => base_1+"e" ; Pl => base_1+"sh" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"a" ;  Pl => base_1+"t" } ;
                   Acc   => table { Sg => base_1+"ën" ; Pl => base_1+"t" } ;
                   Dat   => table { Sg => base_1+"ës" ; Pl => base_1+"ve" } ;
