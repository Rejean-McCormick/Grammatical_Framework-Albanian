mkN356 : Str -> N ;
mkN356 base_1 =
  lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1      ; Pl => base_1     } ;
                     Acc   => table { Sg => base_1      ; Pl => base_1     } ;
                     Dat   => table { Sg => base_1+"i"  ; Pl => base_1+"ve"} ;
                     Ablat => table { Sg => base_1+"i"  ; Pl => base_1+"sh"}
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"a"   ; Pl => base_1+"t"  } ;
                   Acc   => table { Sg => base_1+"an"  ; Pl => base_1+"t"  } ;
                   Dat   => table { Sg => base_1+"at"  ; Pl => base_1+"ve" } ;
                   Ablat => table { Sg => base_1+"at"  ; Pl => base_1+"ve" }
                 }
        } ;
    g = Masc
  } ;

