mkN358 : Str -> N ;
mkN358 base =
  case base of {
    base_1+"ë"+base_2@? => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"ë"+base_2     ; Pl => base_1+"ë"+base_2+"a"  } ;
                         Acc   => table { Sg => base_1+"ë"+base_2     ; Pl => base_1+"ë"+base_2+"a"  } ;
                         Dat   => table { Sg => base_1+base_2+"i"      ; Pl => base_1+"ë"+base_2+"ave"} ;
                         Ablat => table { Sg => base_1+base_2+"i"      ; Pl => base_1+"ë"+base_2+"ash"}
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+base_2+"i"        ; Pl => base_1+"ë"+base_2+"at" } ;
                       Acc   => table { Sg => base_1+base_2+"in"       ; Pl => base_1+"ë"+base_2+"at" } ;
                       Dat   => table { Sg => base_1+base_2+"it"       ; Pl => base_1+"ë"+base_2+"ave"} ;
                       Ablat => table { Sg => base_1+base_2+"it"       ; Pl => base_1+"ë"+base_2+"ave"}
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN358"
  } ;

mkN359 : Str -> N ;
mkN359 base_1 =
  lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1      ; Pl => base_1+"a"   } ;
                     Acc   => table { Sg => base_1      ; Pl => base_1+"a"   } ;
                     Dat   => table { Sg => base_1+"i"  ; Pl => base_1+"ave" } ;
                     Ablat => table { Sg => base_1+"i"  ; Pl => base_1+"ash" }
                   } ;
          Def => table {
                   Nom   => table { Sg => "sh"+base_1+"i"  ; Pl => base_1+"at"  } ;
                   Acc   => table { Sg => "sh"+base_1+"in" ; Pl => base_1+"at"  } ;
                   Dat   => table { Sg => "sh"+base_1+"it" ; Pl => base_1+"ave" } ;
                   Ablat => table { Sg => "sh"+base_1+"it" ; Pl => base_1+"ave" }
                 }
        } ;
    g = Masc
  } ;

mkN360 : Str -> N ;
mkN360 base =
  case base of {
    base_1+"ez"+base_2@? => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"ez"+base_2        ; Pl => base_1+base_2+"ze"    } ;
                         Acc   => table { Sg => base_1+"ez"+base_2        ; Pl => base_1+base_2+"ze"    } ;
                         Dat   => table { Sg => base_1+"ez"+base_2+"je"   ; Pl => base_1+base_2+"zeve"  } ;
                         Ablat => table { Sg => base_1+"ez"+base_2+"je"   ; Pl => base_1+base_2+"zesh"  }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+base_2+"zja"         ; Pl => base_1+base_2+"zet"   } ;
                       Acc   => table { Sg => base_1+"ez"+base_2+"n"      ; Pl => base_1+base_2+"zet"   } ;
                       Dat   => table { Sg => base_1+"ez"+base_2+"s"      ; Pl => base_1+base_2+"zeve"  } ;
                       Ablat => table { Sg => base_1+"ez"+base_2+"s"      ; Pl => base_1+base_2+"zeve"  }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN360"
  } ;