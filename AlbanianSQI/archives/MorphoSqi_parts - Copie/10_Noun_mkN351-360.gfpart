mkN351 : Str -> N ;
mkN351 base =
  case base of {
    base_1+"llë" => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"llë" ; Pl => base_1+"je"   } ;
                         Acc   => table { Sg => base_1+"llë" ; Pl => base_1+"je"   } ;
                         Dat   => table { Sg => base_1+"lle" ; Pl => base_1+"jeve" } ;
                         Ablat => table { Sg => base_1+"lle" ; Pl => base_1+"jesh" }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+"lla"  ; Pl => base_1+"jet"  } ;
                       Acc   => table { Sg => base_1+"llën" ; Pl => base_1+"jet"  } ;
                       Dat   => table { Sg => base_1+"llës" ; Pl => base_1+"jeve" } ;
                       Ablat => table { Sg => base_1+"llës" ; Pl => base_1+"jeve" }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN351"
  } ;

mkN352 : Str -> N ;
mkN352 base =
  case base of {
    base_1+"a"+base_2@(?+?+?) => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"a"+base_2        ; Pl => base_1+"e"+base_2+"na"   } ;
                         Acc   => table { Sg => base_1+"a"+base_2        ; Pl => base_1+"e"+base_2+"na"   } ;
                         Dat   => table { Sg => base_1+"a"+base_2+"i"    ; Pl => base_1+"e"+base_2+"nave" } ;
                         Ablat => table { Sg => base_1+"a"+base_2+"i"    ; Pl => base_1+"e"+base_2+"nash" }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+"a"+base_2+"i"      ; Pl => base_1+"e"+base_2+"nat"  } ;
                       Acc   => table { Sg => base_1+"a"+base_2+"in"     ; Pl => base_1+"e"+base_2+"nat"  } ;
                       Dat   => table { Sg => base_1+"a"+base_2+"it"     ; Pl => base_1+"e"+base_2+"nave" } ;
                       Ablat => table { Sg => base_1+"a"+base_2+"it"     ; Pl => base_1+"e"+base_2+"nave" }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN352"
  } ;

