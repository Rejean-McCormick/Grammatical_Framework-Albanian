                         Acc   => table { Sg => base_1+"ë"    ; Pl => base_1+"ëra"   } ;
                         Dat   => table { Sg => base_1+"e"    ; Pl => base_1+"ërave" } ;
                         Ablat => table { Sg => base_1+"e"    ; Pl => base_1+"ërash" }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+"a"     ; Pl => base_1+"ërat"  } ;
                       Acc   => table { Sg => base_1+"ën"    ; Pl => base_1+"ërat"  } ;
                       Dat   => table { Sg => base_1+"ës"    ; Pl => base_1+"ërave" } ;
                       Ablat => table { Sg => base_1+"ës"    ; Pl => base_1+"ërave" }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN353"
  } ;

