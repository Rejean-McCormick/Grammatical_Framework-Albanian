mkN411 : Str -> N ;
mkN411 base =
  case base of {
    base_1+"ë" => lin N
      { s = table {
              Indef => table {
                         Nom => table {
                                  Sg => base_1+"ë" ;
                                  Pl => base_1+"a"
                                } ;
                         Acc => table {
                                  Sg => base_1+"ë" ;
                                  Pl => base_1+"a"
                                } ;
                         Dat => table {
                                  Sg => base_1+"e" ;
                                  Pl => base_1+"ave"
                                } ;
                         Ablat => table {
                                    Sg => base_1+"e" ;
                                    Pl => base_1+"ash"
                                  }
                       } ;
              Def => table {
                       Nom => table {
                                Sg => base_1+"a" ;
                                Pl => base_1+"at"
                              } ;
                       Acc => table {
                                Sg => base_1+"ën" ;
                                Pl => base_1+"at"
                              } ;
                       Dat => table {
                                Sg => base_1+"ës" ;
                                Pl => base_1+"ave"
                              } ;
                       Ablat => table {
                                  Sg => base_1+"ës" ;
                                  Pl => base_1+"ave"
                                }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN411"
  } ;

mkN412 : Str -> N ;
mkN412 base =
  case base of {
    base_1+"e"+base_2@?+"ë" =>
      let indeSg = base_1+"e"+base_2+"ë" ;
          stem   = base_1+"e"+base_2 ;
          defSg  = base_1+"é"+base_2+"a" ;
      in lin N
      { s = table {
              Indef => table {
                         Nom => table { Sg => indeSg ; Pl => nonExist } ;
                         Acc => table { Sg => indeSg ; Pl => nonExist } ;
                         Dat => table { Sg => stem+"i" ; Pl => nonExist } ;
                         Ablat=> table { Sg => stem+"i" ; Pl => nonExist }
                       } ;
              Def => table {
                       Nom => table { Sg => defSg ; Pl => nonExist } ;
                       Acc => table { Sg => defSg+"n" ; Pl => nonExist } ;
                       Dat => table { Sg => defSg+"t" ; Pl => nonExist } ;
                       Ablat=> table { Sg => defSg+"t" ; Pl => nonExist }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN412"
  } ;

mkN413 : Str -> N ;
mkN413 base =
  case base of {
    base_1+"e"+base_2@(?+?) =>
      let indeSg = base_1+"e"+base_2 ;
          defSg  = base_1+"é"+base_2+"t" ;
      in lin N
      { s = table {
              Indef => table {
                         Nom => table { Sg => indeSg ; Pl => nonExist } ;
                         Acc => table { Sg => indeSg ; Pl => nonExist } ;
                         Dat => table { Sg => indeSg+"i" ; Pl => nonExist } ;
                         Ablat=> table { Sg => indeSg+"i" ; Pl => nonExist }
                       } ;
              Def => table {
                       Nom => table { Sg => defSg ; Pl => nonExist } ;
                       Acc => table { Sg => defSg ; Pl => nonExist } ;
                       Dat => table { Sg => defSg+"t" ; Pl => nonExist } ;
                       Ablat=> table { Sg => defSg+"t" ; Pl => nonExist }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN413"
  } ;

