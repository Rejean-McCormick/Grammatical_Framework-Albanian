mkN420 : Str -> N ;
mkN420 base_1 =
  lin N
  { s = table {
          Indef => table {
                     Nom => table { Sg => base_1 ;      Pl => base_1+"ra"   } ;
                     Acc => table { Sg => base_1 ;      Pl => base_1+"ra"   } ;
                     Dat => table { Sg => base_1+"e" ;  Pl => base_1+"rave" } ;
                     Ablat=> table { Sg => base_1+"e" ; Pl => base_1+"rash" }
                   } ;
          Def => table {
                   Nom => table { Sg => base_1+"a"  ;  Pl => base_1+"rat"  } ;
                   Acc => table { Sg => base_1+"ën" ;  Pl => base_1+"rat"  } ;
                   Dat => table { Sg => base_1+"ës" ;  Pl => base_1+"rave" } ;
