mkN481 : Str -> N ;
mkN481 base =
  case base of {
    base_1+"s" => lin N
      { s = table {
              Indef => table {
                         Nom => table {
                                  Sg => base_1+"s" ;
                                  Pl => base_1+"a"
                                } ;
                         Acc => table {
                                  Sg => base_1+"s" ;
                                  Pl => base_1+"a"
                                } ;
                         Dat => table {
                                  Sg => base_1+"si" ; --guessed
                                  Pl => base_1+"sve" --guessed
                                } ;
                         Ablat => table {
                                    Sg => base_1+"si" ; --guessed
                                    Pl => base_1+"ssh" --guessed
                                  }
                       } ;
              Def => table {
                       Nom => table {
                                Sg => base_1+"si" ;
                                Pl => base_1+"sit"
                              } ;
                       Acc => table {
                                Sg => nonExist ;
                                Pl => nonExist
                              } ;
                       Dat => table {
                                Sg => base_1+"sit" ; --guessed
                                Pl => nonExist
                              } ;
                       Ablat => table {
                                  Sg => base_1+"sit" ; --guessed
                                  Pl => nonExist
                                }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN481"
  } ;

