                                  Pl => base_1+"ë"+base_2+"ve" --guessed
                                } ;
                         Ablat => table {
                                    Sg => base_1+"ë"+base_2+"e" ; --guessed
                                    Pl => base_1+"ë"+base_2+"sh" --guessed
                                  }
