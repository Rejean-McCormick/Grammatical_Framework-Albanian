                          Pl => table { P1 => "(për)"+base_1+"ukëshim" ; P2 => "(për)"+base_1+"ukëshit" ; P3 => "(për)"+base_1+"ukëshin" }
                        }
  } ;

mkV018 : Str -> V ;
mkV018 base_1 =
  lin V
  { Indicative = table {
                   Pres => table {
                             Sg => table { P1 => base_1 ; P2 => base_1 ; P3 => base_1 } ;
                             Pl => table { P1 => base_1+"im" ; P2 => base_1+"ni" ; P3 => base_1+"in" }
                           } ;
                   Past => table {
                             Sg => table { P1 => "kam "+base_1+"ur" ; P2 => "ke "+base_1+"ur" ; P3 => "ka "+base_1+"ur" } ;
                             Pl => table { P1 => "kemi "+base_1+"ur" ; P2 => "keni "+base_1+"ur" ; P3 => "kanë "+base_1+"ur" }
                           } ;
                   Aorist => table {
                               Sg => table { P1 => base_1 ; P2 => base_1+"e" ; P3 => base_1+"i" } ;
                               Pl => table { P1 => base_1+"ëm" ; P2 => base_1+"ët" ; P3 => base_1+"ën" }
                             } ;
                   Imperfect => table {
                                  Sg => table { P1 => base_1+"ja" ; P2 => base_1+"je" ; P3 => base_1+"te" } ;
                                  Pl => table { P1 => base_1+"nim" ; P2 => base_1+"nit" ; P3 => base_1+"nin" }
                                }
                 } ;
    Imperative = table { Sg => base_1 ; Pl => base_1+"ni" } ;
    participle = base_1+"ur" ;
    pres_optative = table {
                      Sg => table { P1 => base_1+"sha" ; P2 => base_1+"sh" ; P3 => base_1+"të" } ;
                      Pl => table { P1 => base_1+"shim" ; P2 => base_1+"shi" ; P3 => base_1+"shin" }
                    } ;
    perf_optative = table {
