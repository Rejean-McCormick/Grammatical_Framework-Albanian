mkV024 : Str -> V ;
mkV024 base =
  case base of {
    base_1+"j" =>
      let
        pres1 : Str = base_1+"j" ;
        pres23 : Str = base_1+"n" ;
        pres1pl : Str = base_1+"jmë" ;
        pres2pl : Str = base_1+"ni" ;
        pres3pl : Str = base_1+"jnë" ;

        aorStem : Str = base_1+"t" ;
        impS : Str = base_1 ;              -- heuristic for imperfect
        part : Str = base_1+"tur" ;
        partStem : Str = base_1+"tu" ;

        optBase : Str = aorStem ;
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => pres1 ; P2 => pres23 ; P3 => pres23 } ;
            Pl => table { P1 => pres1pl ; P2 => pres2pl ; P3 => pres3pl }
          } ;
          Past => table {
            Sg => table { P1 => "kam "+part ; P2 => "ke "+part ; P3 => "ka "+part } ;
            Pl => table { P1 => "kemi "+part ; P2 => "keni "+part ; P3 => "kanë "+part }
          } ;
          Aorist => table {
            Sg => table { P1 => aorStem+"a" ; P2 => aorStem+"e" ; P3 => aorStem+"i" } ;
            Pl => table { P1 => aorStem+"ëm" ; P2 => aorStem+"ët" ; P3 => aorStem+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => impS+"ja" ; P2 => impS+"je" ; P3 => impS+"te" } ;
            Pl => table { P1 => impS+"nim" ; P2 => impS+"nit" ; P3 => impS+"nin" }
          }
        } ;
        Imperative = table { Sg => base_1 ; Pl => pres2pl } ;
        participle = part ;

        pres_optative = table {
          Sg => table { P1 => optSh+"a" ; P2 => optSh ; P3 => optBase+"të" } ;
          Pl => table { P1 => optSh+"im" ; P2 => optSh+"i" ; P3 => optSh+"in" }
        } ;

        perf_optative = table {
          Sg => table { P1 => "paça "+part ; P2 => "paç "+part ; P3 => "pastë "+part } ;
          Pl => table { P1 => "paçim "+part ; P2 => "paçi "+part ; P3 => "paçin "+part }
        } ;

        pres_admirative = table {
          Sg => table { P1 => partStem+"kam" ; P2 => partStem+"ke" ; P3 => partStem+"ka" } ;
          Pl => table { P1 => partStem+"kemi" ; P2 => partStem+"keni" ; P3 => partStem+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
          Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV024"
  } ;

mkV025 : Str -> V ;
mkV025 base =
  case base of {
    base_1+"y"+base_2@?+"j" =>
      let
        stemY : Str = base_1+"y"+base_2 ;           -- e.g. fry-
        pres1 : Str = stemY+"j" ;
        pres23 : Str = stemY+"n" ;
        pres1pl : Str = stemY+"jmë" ;
        pres2pl : Str = stemY+"ni" ;
        pres3pl : Str = stemY+"jnë" ;

        aorBase : Str = base_1+base_2 ;            -- drop y (per given 1sg aorist)
        impS : Str = stemY ;                        -- heuristic

        part : Str = stemY+"rë" ;                   -- more standard than bare -r
        partStem : Str = stemY+"r" ;                -- drop ë

        optBase : Str = aorBase ;                   -- consonant stem -> -sh
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => pres1 ; P2 => pres23 ; P3 => pres23 } ;
            Pl => table { P1 => pres1pl ; P2 => pres2pl ; P3 => pres3pl }
          } ;
          Past => table {
            Sg => table { P1 => "kam "+part ; P2 => "ke "+part ; P3 => "ka "+part } ;
            Pl => table { P1 => "kemi "+part ; P2 => "keni "+part ; P3 => "kanë "+part }
          } ;
          Aorist => table {
            Sg => table { P1 => aorBase+"va" ; P2 => aorBase+"ve" ; P3 => aorBase+"u" } ;
            Pl => table { P1 => aorBase+"më" ; P2 => aorBase+"të" ; P3 => aorBase+"në" }
          } ;
          Imperfect => table {
            Sg => table { P1 => impS+"ja" ; P2 => impS+"je" ; P3 => impS+"te" } ;
            Pl => table { P1 => impS+"nim" ; P2 => impS+"nit" ; P3 => impS+"nin" }
          }
        } ;
        Imperative = table { Sg => stemY ; Pl => pres2pl } ;
        participle = part ;

        pres_optative = table {
          Sg => table { P1 => optSh+"a" ; P2 => optSh ; P3 => optBase+"të" } ;
          Pl => table { P1 => optSh+"im" ; P2 => optSh+"i" ; P3 => optSh+"in" }
        } ;

        perf_optative = table {
          Sg => table { P1 => "paça "+part ; P2 => "paç "+part ; P3 => "pastë "+part } ;
          Pl => table { P1 => "paçim "+part ; P2 => "paçi "+part ; P3 => "paçin "+part }
        } ;

        pres_admirative = table {
          Sg => table { P1 => partStem+"kam" ; P2 => partStem+"ke" ; P3 => partStem+"ka" } ;
          Pl => table { P1 => partStem+"kemi" ; P2 => partStem+"keni" ; P3 => partStem+"kan" }
        } ;

        imperf_admirative = table {
          Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
          Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV025"
  } ;

mkV026 : Str -> V ;
mkV026 base =
  case base of {
    base_1+"e"+base_2@(?+?) =>
      let
        presS : Str = base_1+"e"+base_2 ;
        aorS  : Str = base_1+"o"+base_2 ;
        impS  : Str = presS ;
        part  : Str = base_1+"e"+base_2+"ur" ;
        partStem : Str = base_1+"e"+base_2+"u" ;
        optBase : Str = aorS ;
