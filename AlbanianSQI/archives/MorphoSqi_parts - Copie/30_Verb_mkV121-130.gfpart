                                      P2 => "u "+base_1+"u"+"këshe" ;
                                      P3 => "u "+base_1+"u"+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => "u "+base_1+"u"+"këshim" ;
                                      P2 => "u "+base_1+"u"+"këshit" ;
                                      P3 => "u "+base_1+"u"+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV124"
  } ;

mkV125 : Str -> V ;
mkV125 base =
  case base of {
    base_1+base_2@?+"rrtë" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+base_2+"rr" ;
                                         P2 => base_1+"err" ;
                                         P3 => base_1+"err"
                                       } ;
                                 Pl => table {
                                         P1 => base_1+base_2+"rrim" ;
                                         P2 => base_1+"errni" ;
                                         P3 => base_1+base_2+"rrin"
                                       }
                               } ;
                       Past => table {
                                 Sg => table {
                                         P1 => "kam "+base_1+base_2+"rrë" ;
                                         P2 => "ke "+base_1+base_2+"rrë" ;
                                         P3 => "ka "+base_1+base_2+"rrë"
                                       } ;
                                 Pl => table {
                                         P1 => "kemi "+base_1+base_2+"rrë" ;
                                         P2 => "keni "+base_1+base_2+"rrë" ;
                                         P3 => "kanë "+base_1+base_2+"rrë"
                                       }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+"or"+base_2 ;
                                           P2 => base_1+"or"+"e" ;
                                           P3 => base_1+"or"+"i"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"or"+"ëm" ;
                                           P2 => base_1+"or"+"ët" ;
                                           P3 => base_1+"or"+"ën"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+"errja" ;
                                              P2 => base_1+"errje" ;
                                              P3 => base_1+"errte"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+"errnim" ;
                                              P2 => base_1+"errnit" ;
                                              P3 => base_1+"errnin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"err" ;
                       Pl => base_1+"errni"
                     } ;
        participle = base_1+base_2+"rrë" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => base_1+"or"+"sha" ;
                                  P2 => base_1+"or"+"sh" ;
                                  P3 => base_1+"or"+"të"
                                } ;
                          Pl => table {
                                  P1 => base_1+"or"+"shim" ;
                                  P2 => base_1+"or"+"shi" ;
                                  P3 => base_1+"or"+"shin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table {
                                  P1 => "paça "+base_1+base_2+"rrë" ;
                                  P2 => "paç "+base_1+base_2+"rrë" ;
                                  P3 => "pastë "+base_1+base_2+"rrë"
                                } ;
                          Pl => table {
                                  P1 => "paçim "+base_1+base_2+"rrë" ;
                                  P2 => "paçi "+base_1+base_2+"rrë" ;
                                  P3 => "paçin "+base_1+base_2+"rrë"
                                }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => base_1+base_2+"rr"+"kam" ;
                                    P2 => base_1+base_2+"rr"+"ke" ;
                                    P3 => base_1+base_2+"rr"+"ka"
                                  } ;
                            Pl => table {
                                    P1 => base_1+base_2+"rr"+"kemi" ;
                                    P2 => base_1+base_2+"rr"+"keni" ;
                                    P3 => base_1+base_2+"rr"+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => base_1+base_2+"rr"+"kësha" ;
                                      P2 => base_1+base_2+"rr"+"këshe" ;
                                      P3 => base_1+base_2+"rr"+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => base_1+base_2+"rr"+"këshim" ;
                                      P2 => base_1+base_2+"rr"+"këshit" ;
                                      P3 => base_1+base_2+"rr"+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV125"
  } ;

mkV126 : Str -> V ;
mkV126 base =
  case base of {
    base_1+"ash"+base_2@? => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"ash"+base_2 ;
                                         P2 => nonExist ;
                                         P3 => nonExist
                                       } ;
                                 Pl => table {
                                         P1 => nonExist ;
                                         P2 => nonExist ;
                                         P3 => nonExist
                                       }
                               } ;
                       Past => table {
                                 Sg => table {
                                         P1 => "kam "+base_1+base_2+"në" ;
                                         P2 => "ke "+base_1+base_2+"në" ;
                                         P3 => "ka "+base_1+base_2+"në"
                                       } ;
                                 Pl => table {
                                         P1 => "kemi "+base_1+base_2+"në" ;
                                         P2 => "keni "+base_1+base_2+"në" ;
                                         P3 => "kanë "+base_1+base_2+"në"
                                       }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+"ash"+base_2 ;
                                           P2 => base_1+"e" ;
                                           P3 => base_1+"a"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"am"+base_2 ;
                                           P2 => base_1+"at"+base_2 ;
                                           P3 => base_1+"an"+base_2
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => nonExist ;
                                              P2 => nonExist ;
                                              P3 => nonExist
                                            } ;
                                      Pl => table {
                                              P1 => nonExist ;
                                              P2 => nonExist ;
                                              P3 => nonExist
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => nonExist ;
                       Pl => nonExist
                     } ;
        participle = base_1+base_2+"në" ;
        -- thënça / dhënça type
        pres_optative = table {
                          Sg => table {
                                  P1 => base_1+base_2+"nça" ;
                                  P2 => base_1+base_2+"nç" ;
                                  P3 => base_1+base_2+"nstë"
                                } ;
                          Pl => table {
                                  P1 => base_1+base_2+"nçim" ;
                                  P2 => base_1+base_2+"nçi" ;
                                  P3 => base_1+base_2+"nçin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table {
                                  P1 => "paça "+base_1+base_2+"në" ;
                                  P2 => "paç "+base_1+base_2+"në" ;
                                  P3 => "pastë "+base_1+base_2+"në"
                                } ;
                          Pl => table {
                                  P1 => "paçim "+base_1+base_2+"në" ;
                                  P2 => "paçi "+base_1+base_2+"në" ;
                                  P3 => "paçin "+base_1+base_2+"në"
                                }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => base_1+base_2+"n"+"kam" ;
                                    P2 => base_1+base_2+"n"+"ke" ;
                                    P3 => base_1+base_2+"n"+"ka"
                                  } ;
                            Pl => table {
                                    P1 => base_1+base_2+"n"+"kemi" ;
                                    P2 => base_1+base_2+"n"+"keni" ;
                                    P3 => base_1+base_2+"n"+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => base_1+base_2+"n"+"kësha" ;
                                      P2 => base_1+base_2+"n"+"këshe" ;
                                      P3 => base_1+base_2+"n"+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => base_1+base_2+"n"+"këshim" ;
