mkV121 : Str -> V ;
mkV121 base =
  case base of {
    base_1+"oj" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"oj" ;
                                         P2 => base_1+"on" ;
                                         P3 => base_1+"on"
                                       } ;
                                 Pl => table {
                                         P1 => base_1+"ojmë" ;
                                         P2 => base_1+"oni" ;
                                         P3 => base_1+"ojnë"
                                       }
                               } ;
                       -- present perfect
                       Past => table {
                                 Sg => table {
                                         P1 => "kam "+base_1+"uar" ;
                                         P2 => "ke "+base_1+"uar" ;
                                         P3 => "ka "+base_1+"uar"
                                       } ;
                                 Pl => table {
                                         P1 => "kemi "+base_1+"uar" ;
                                         P2 => "keni "+base_1+"uar" ;
                                         P3 => "kanë "+base_1+"uar"
                                       }
                               } ;
                       -- past definite
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+"ova" ;
                                           P2 => base_1+"ove" ;
                                           P3 => base_1+"oi"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"uam" ;
                                           P2 => base_1+"uat" ;
                                           P3 => base_1+"uan"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+"oja" ;
                                              P2 => base_1+"oje" ;
                                              P3 => base_1+"onte"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+"onim" ;
                                              P2 => base_1+"onit" ;
                                              P3 => base_1+"onin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"o" ;
                       Pl => base_1+"oni"
                     } ;
        participle = base_1+"uar" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => base_1+"ofsha" ;
                                  P2 => base_1+"ofsh" ;
                                  P3 => base_1+"oftë"
                                } ;
                          Pl => table {
                                  P1 => base_1+"ofshim" ;
                                  P2 => base_1+"ofshi" ;
                                  P3 => base_1+"ofshin"
                                }
                        } ;
        -- perfect optative: paça + participle
        perf_optative = table {
                          Sg => table {
                                  P1 => "paça "+base_1+"uar" ;
                                  P2 => "paç "+base_1+"uar" ;
                                  P3 => "pastë "+base_1+"uar"
                                } ;
                          Pl => table {
                                  P1 => "paçim "+base_1+"uar" ;
                                  P2 => "paçi "+base_1+"uar" ;
                                  P3 => "paçin "+base_1+"uar"
                                }
                        } ;
        -- admirative: participle-stem (punua-) + present/imperfect of kam
        pres_admirative = table {
                            Sg => table {
                                    P1 => base_1+"ua"+"kam" ;
                                    P2 => base_1+"ua"+"ke" ;
                                    P3 => base_1+"ua"+"ka"
                                  } ;
                            Pl => table {
                                    P1 => base_1+"ua"+"kemi" ;
                                    P2 => base_1+"ua"+"keni" ;
                                    P3 => base_1+"ua"+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => base_1+"ua"+"kësha" ;
                                      P2 => base_1+"ua"+"këshe" ;
                                      P3 => base_1+"ua"+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => base_1+"ua"+"këshim" ;
                                      P2 => base_1+"ua"+"këshit" ;
                                      P3 => base_1+"ua"+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV121"
  } ;

mkV122 : Str -> V ;
mkV122 base =
  case base of {
    base_1+"âj" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"âj" ;
                                         P2 => base_1+"ân" ;
                                         P3 => base_1+"ân"
                                       } ;
                                 Pl => table {
                                         P1 => base_1+"âjmë" ;
                                         P2 => base_1+"âni" ;
                                         P3 => base_1+"âjnë"
                                       }
                               } ;
                       Past => table {
                                 Sg => table {
                                         P1 => "kam "+base_1+"â" ;
                                         P2 => "ke "+base_1+"â" ;
                                         P3 => "ka "+base_1+"â"
                                       } ;
                                 Pl => table {
                                         P1 => "kemi "+base_1+"â" ;
                                         P2 => "keni "+base_1+"â" ;
                                         P3 => "kanë "+base_1+"â"
                                       }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+"âna" ;
                                           P2 => base_1+"âne" ;
                                           P3 => base_1+"âni"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"âmë" ;
                                           P2 => base_1+"âtë" ;
                                           P3 => base_1+"ânë"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+"âja" ;
                                              P2 => base_1+"âje" ;
                                              P3 => base_1+"ânte"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+"ânim" ;
                                              P2 => base_1+"ânit" ;
                                              P3 => base_1+"ânin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"âj" ;
                       Pl => base_1+"âni"
                     } ;
        -- participle of <bâj> is <bâ>
        participle = base_1+"â" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => base_1+"ânça" ;
                                  P2 => base_1+"ânç" ;
                                  P3 => base_1+"ânstë"
                                } ;
                          Pl => table {
                                  P1 => base_1+"ânçim" ;
                                  P2 => base_1+"ânçi" ;
                                  P3 => base_1+"ânçin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table {
                                  P1 => "paça "+base_1+"â" ;
                                  P2 => "paç "+base_1+"â" ;
                                  P3 => "pastë "+base_1+"â"
                                } ;
                          Pl => table {
                                  P1 => "paçim "+base_1+"â" ;
                                  P2 => "paçi "+base_1+"â" ;
                                  P3 => "paçin "+base_1+"â"
                                }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => base_1+"â"+"kam" ;
                                    P2 => base_1+"â"+"ke" ;
                                    P3 => base_1+"â"+"ka"
                                  } ;
                            Pl => table {
                                    P1 => base_1+"â"+"kemi" ;
                                    P2 => base_1+"â"+"keni" ;
                                    P3 => base_1+"â"+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => base_1+"â"+"kësha" ;
                                      P2 => base_1+"â"+"këshe" ;
                                      P3 => base_1+"â"+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => base_1+"â"+"këshim" ;
                                      P2 => base_1+"â"+"këshit" ;
                                      P3 => base_1+"â"+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV122"
  } ;

mkV123 : Str -> V ;
mkV123 base =
  case base of {
    base_1+"i"+base_2@?+"et" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"i"+base_2+"em" ;
                                         P2 => base_1+"i"+base_2+"esh" ;
                                         P3 => base_1+"i"+base_2+"et"
                                       } ;
                                 Pl => table {
                                         P1 => base_1+"i"+base_2+"emi" ;
                                         P2 => base_1+"i"+base_2+"eni" ;
                                         P3 => base_1+"i"+base_2+"en"
                                       }
                               } ;
                       Past => table {
                                 Sg => table {
                                         P1 => "jam "+base_1+"a"+base_2+"ë" ;
                                         P2 => "je "+base_1+"a"+base_2+"ë" ;
                                         P3 => "është "+base_1+"a"+base_2+"ë"
                                       } ;
                                 Pl => table {
                                         P1 => "jemi "+base_1+"a"+base_2+"ë" ;
                                         P2 => "jeni "+base_1+"a"+base_2+"ë" ;
                                         P3 => "janë "+base_1+"a"+base_2+"ë"
                                       }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => "u "+base_1+"o"+base_2+"a" ;
                                           P2 => "u "+base_1+"o"+base_2+"e" ;
                                           P3 => "u "+base_1+"o"+base_2
                                         } ;
                                   Pl => table {
                                           P1 => "u "+base_1+"o"+base_2+"ëm" ;
                                           P2 => "u "+base_1+"o"+base_2+"ët" ;
                                           P3 => "u "+base_1+"o"+base_2+"ën"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+"i"+base_2+"esha" ;
                                              P2 => base_1+"i"+base_2+"eshe" ;
                                              P3 => base_1+"i"+base_2+"ej"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+"i"+base_2+"eshim" ;
                                              P2 => base_1+"i"+base_2+"eshit" ;
                                              P3 => base_1+"i"+base_2+"eshin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"i"+base_2+"u" ;
                       Pl => base_1+"i"+base_2+"uni"
                     } ;
        participle = base_1+"a"+base_2+"ë" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => "u "+base_1+"o"+base_2+"sha" ;
                                  P2 => "u "+base_1+"o"+base_2+"sh" ;
                                  P3 => "u "+base_1+"o"+base_2+"të"
                                } ;
                          Pl => table {
                                  P1 => "u "+base_1+"o"+base_2+"shim" ;
                                  P2 => "u "+base_1+"o"+base_2+"shi" ;
                                  P3 => "u "+base_1+"o"+base_2+"shin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table {
                                  P1 => "qofsha "+base_1+"a"+base_2+"ë" ;
                                  P2 => "qofsh "+base_1+"a"+base_2+"ë" ;
                                  P3 => "qoftë "+base_1+"a"+base_2+"ë"
                                } ;
                          Pl => table {
                                  P1 => "qofshim "+base_1+"a"+base_2+"ë" ;
                                  P2 => "qofshi "+base_1+"a"+base_2+"ë" ;
                                  P3 => "qofshin "+base_1+"a"+base_2+"ë"
                                }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => "u "+base_1+"a"+base_2+"kam" ;
                                    P2 => "u "+base_1+"a"+base_2+"ke" ;
                                    P3 => "u "+base_1+"a"+base_2+"ka"
                                  } ;
                            Pl => table {
                                    P1 => "u "+base_1+"a"+base_2+"kemi" ;
                                    P2 => "u "+base_1+"a"+base_2+"keni" ;
                                    P3 => "u "+base_1+"a"+base_2+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
                                      P1 => "u "+base_1+"a"+base_2+"kësha" ;
                                      P2 => "u "+base_1+"a"+base_2+"këshe" ;
                                      P3 => "u "+base_1+"a"+base_2+"kësh"
                                    } ;
                              Pl => table {
                                      P1 => "u "+base_1+"a"+base_2+"këshim" ;
                                      P2 => "u "+base_1+"a"+base_2+"këshit" ;
                                      P3 => "u "+base_1+"a"+base_2+"këshin"
                                    }
                            }
      };
    _ => error "Can't apply paradigm mkV123"
  } ;

