                                  } ;
                            Pl => table {
                                    P1 => "u "+base_1+"u"+"kemi" ;
                                    P2 => "u "+base_1+"u"+"keni" ;
                                    P3 => "u "+base_1+"u"+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table {
