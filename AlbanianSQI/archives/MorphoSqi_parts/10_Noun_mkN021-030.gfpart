                     Nom   => table { Sg => base_1 ;      Pl => plInd } ;
                     Acc   => table { Sg => base_1 ;      Pl => plInd } ;
                     Dat   => table { Sg => base_1+"je" ; Pl => plInd+"ve" } ;
                     Ablat => table { Sg => base_1+"je" ; Pl => plInd+"sh" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"ja" ;  Pl => plDef } ;
                   Acc   => table { Sg => base_1+"në" ;  Pl => plDef } ;
                   Dat   => table { Sg => base_1+"së" ;  Pl => plInd+"ve" } ;
                   Ablat => table { Sg => base_1+"së" ;  Pl => plInd+"ve" }
                 }
        } ;
    g = Fem
  } ;

