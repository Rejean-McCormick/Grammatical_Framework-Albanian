mkN021 : Str -> N ;
mkN021 base_1 =
  let plInd : Str = base_1 ;
      plDef : Str = plInd+"t" ;
  in lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1 ;      Pl => plInd } ;
                     Acc   => table { Sg => base_1 ;      Pl => plInd } ;
                     Dat   => table { Sg => base_1+"ri" ; Pl => plInd+"ve" } ;
                     Ablat => table { Sg => base_1+"ri" ; Pl => plInd+"sh" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"ri" ;  Pl => plDef } ;
                   Acc   => table { Sg => base_1+"rin" ; Pl => plDef } ;
                   Dat   => table { Sg => base_1+"rit" ; Pl => plInd+"ve" } ;
                   Ablat => table { Sg => base_1+"rit" ; Pl => plInd+"ve" }
                 }
        } ;
    g = Masc
  } ;

mkN022 : Str -> N ;
mkN022 base =
  case base of {
    base_1+"e" =>
      let sgInd : Str = base_1+"e" ;
          plInd : Str = base_1+"é" ;
          sgDefNom : Str = base_1+"éja" ;
          plDef : Str = base_1+"étë" ;
      in lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => sgInd ;        Pl => plInd } ;
                         Acc   => table { Sg => sgInd ;        Pl => plInd } ;
                         Dat   => table { Sg => base_1+"eje" ; Pl => plInd+"ve" } ;
                         Ablat => table { Sg => base_1+"eje" ; Pl => plInd+"sh" }
                       } ;
              Def => table {
                       Nom   => table { Sg => sgDefNom ;      Pl => plDef } ;
                       Acc   => table { Sg => base_1+"én" ;   Pl => plDef } ;
                       Dat   => table { Sg => base_1+"és" ;   Pl => plInd+"ve" } ;
                       Ablat => table { Sg => base_1+"és" ;   Pl => plInd+"ve" }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN022"
  } ;

mkN023 : Str -> N ;
mkN023 base_1 =
  let plInd : Str = base_1 ;
      plDef : Str = plInd+"t" ;
  in lin N
  { s = table {
