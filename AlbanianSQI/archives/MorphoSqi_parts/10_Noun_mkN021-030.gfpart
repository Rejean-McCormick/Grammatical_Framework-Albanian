              Indef => table {
                         Nom   => table { Sg => base_1+"r" ;  Pl => base_1+"j" } ;
                         Acc   => table { Sg => base_1+"r" ;  Pl => base_1+"j" } ;
                         Dat   => table { Sg => base_1+"ri" ; Pl => base_1+"jve" } ;
                         Ablat => table { Sg => base_1+"ri" ; Pl => base_1+"jsh" }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+"ri" ;  Pl => base_1+"jtë" } ;
                       Acc   => table { Sg => base_1+"rin" ; Pl => base_1+"jtë" } ;
                       Dat   => table { Sg => base_1+"rit" ; Pl => base_1+"jve" } ;
                       Ablat => table { Sg => base_1+"rit" ; Pl => base_1+"jve" }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN029"
  } ;

mkN030 : Str -> N ;
mkN030 base_1 =
  let plInd : Str = base_1+"je" ;
      plDef : Str = base_1+"jet" ;
  in lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1 ;        Pl => plInd } ;
                     Acc   => table { Sg => base_1 ;        Pl => plInd } ;
                     Dat   => table { Sg => base_1+"je" ;   Pl => base_1+"jeve" } ;
                     Ablat => table { Sg => base_1+"je" ;   Pl => base_1+"jesh" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"ja" ;   Pl => plDef } ;
                   Acc   => table { Sg => base_1+"jen" ;  Pl => plDef } ;
                   Dat   => table { Sg => base_1+"s" ;    Pl => base_1+"jeve" } ;
                   Ablat => table { Sg => base_1+"s" ;    Pl => base_1+"jeve" }
                 }
        } ;
    g = Fem
  } ;