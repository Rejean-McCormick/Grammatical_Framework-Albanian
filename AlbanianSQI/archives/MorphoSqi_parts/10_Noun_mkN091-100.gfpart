                   Acc => table { Sg => base_1 + "jan" ; Pl => base_1 + "t" } ;
                   Dat => table { Sg => base_1 + "jas" ; Pl => base_1 + "ve" } ;
                   Ablat => table { Sg => base_1 + "jas" ; Pl => base_1 + "ve" }
                 }
        } ;
