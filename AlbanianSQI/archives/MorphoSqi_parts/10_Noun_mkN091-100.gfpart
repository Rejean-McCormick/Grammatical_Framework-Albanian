                   Dat => table { Sg => base_1 + "s" ; Pl => base_1 + "ëve" } ;
                   Ablat => table { Sg => base_1 + "s" ; Pl => base_1 + "ëve" }
                 }
        } ;
    g = Fem
  } ;

mkN098 : Str -> N ;
mkN098 base_1 =
  let pl = base_1 + "j" ;
      plDef = base_1 + "jtë"
  in lin N
  { s = table {
          Indef => table {
                     Nom => table { Sg => base_1 ; Pl => pl } ;
                     Acc => table { Sg => base_1 ; Pl => pl } ;
                     Dat => table { Sg => base_1 + "u" ; Pl => base_1 + "jve" } ;
                     Ablat => table { Sg => base_1 + "u" ; Pl => base_1 + "jsh" }
                   } ;
          Def => table {
                   Nom => table { Sg => base_1 + "u" ; Pl => plDef } ;
                   Acc => table { Sg => base_1 + "un" ; Pl => plDef } ;
                   Dat => table { Sg => base_1 + "ut" ; Pl => base_1 + "jve" } ;
                   Ablat => table { Sg => base_1 + "ut" ; Pl => base_1 + "jve" }
                 }
        } ;
    g = Masc
  } ;

mkN099 : Str -> N ;
mkN099 base =
  case base of {
    base_1 + "m" => lin N
      let sg = base_1 + "m" in
      { s = table {
              Indef => table {
                         Nom => table { Sg => sg ; Pl => nonExist } ;
                         Acc => table { Sg => sg ; Pl => nonExist } ;
                         Dat => table { Sg => sg + "i" ; Pl => nonExist } ;
                         Ablat => table { Sg => sg + "i" ; Pl => nonExist }
                       } ;
              Def => table {
                       Nom => table { Sg => sg + "i" ; Pl => nonExist } ;
                       Acc => table { Sg => sg + "in" ; Pl => nonExist } ;
                       Dat => table { Sg => sg + "it" ; Pl => nonExist } ;
                       Ablat => table { Sg => sg + "it" ; Pl => nonExist }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN099"
  } ;

