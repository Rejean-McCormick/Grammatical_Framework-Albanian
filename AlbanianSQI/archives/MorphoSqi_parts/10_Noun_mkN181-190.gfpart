                         Dat => table { Sg => base_1+"ku" ; Pl => base_1+"qve" } ;
                         Ablat=> table { Sg => base_1+"ku" ; Pl => base_1+"qish" }
                       } ;
              Def => table {
                       Nom => table { Sg => base_1+"ku" ;  Pl => base_1+"qit" } ;
                       Acc => table { Sg => base_1+"kun" ; Pl => base_1+"qit" } ;
                       Dat => table { Sg => base_1+"kut" ; Pl => base_1+"qve" } ;
                       Ablat=> table { Sg => base_1+"kut" ; Pl => base_1+"qve" }
