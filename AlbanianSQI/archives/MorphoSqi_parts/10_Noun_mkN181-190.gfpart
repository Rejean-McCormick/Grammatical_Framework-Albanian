    base_1+"ë" => lin N
      { s = table {
              Indef => table {
                         Nom => table { Sg => base_1+"ë" ;   Pl => base_1+"ëra" } ;
                         Acc => table { Sg => base_1+"ë" ;   Pl => base_1+"ëra" } ;
