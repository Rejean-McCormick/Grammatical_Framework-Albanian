mkN181 : Str -> N ;
mkN181 base =
  case base of {
    base_1+"e"+base_2@("ndth"|"dh"|?) => lin N
      { s = table {
              Indef => table {
                         Nom => table { Sg => base_1+"e"+base_2 ; Pl => nonExist } ;
                         Acc => table { Sg => base_1+"e"+base_2 ; Pl => nonExist } ;
                         Dat => table { Sg => base_1+"e"+base_2+"i" ; Pl => nonExist } ;
                         Ablat=> table { Sg => base_1+"e"+base_2+"i" ; Pl => nonExist }
                       } ;
              Def => table {
                       Nom => table { Sg => base_1+"é"+base_2+"i" ;  Pl => nonExist } ;
                       Acc => table { Sg => base_1+"é"+base_2+"in" ; Pl => nonExist } ;
                       Dat => table { Sg => base_1+"é"+base_2+"it" ; Pl => nonExist } ;
                       Ablat=> table { Sg => base_1+"é"+base_2+"it" ; Pl => nonExist }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN181"
  } ;

mkN182 : Str -> N ;
mkN182 base =
  case base of {
    base_1+"o" => lin N
      { s = table {
              Indef => table {
                         Nom => table { Sg => base_1+"o" ;  Pl => base_1+"o" } ;
                         Acc => table { Sg => base_1+"o" ;  Pl => base_1+"o" } ;
                         Dat => table { Sg => base_1+"oi" ; Pl => base_1+"ove" } ;
                         Ablat=> table { Sg => base_1+"oi" ; Pl => base_1+"osh" }
                       } ;
              Def => table {
                       Nom => table { Sg => base_1+"ua" ;  Pl => base_1+"ot" } ;
                       Acc => table { Sg => base_1+"uan" ; Pl => base_1+"ot" } ;
                       Dat => table { Sg => base_1+"uat" ; Pl => base_1+"ove" } ;
                       Ablat=> table { Sg => base_1+"uat" ; Pl => base_1+"ove" }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN182"
  } ;

