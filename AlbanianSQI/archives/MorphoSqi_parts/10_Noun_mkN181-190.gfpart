mkN190 : Str -> N ;
mkN190 base_1 =
  lin N
  { s = table {
          Indef => table {
                     Nom => table { Sg => base_1 ;     Pl => base_1+"ja" } ;
                     Acc => table { Sg => base_1 ;     Pl => base_1+"ja" } ;
                     Dat => table { Sg => base_1+"je" ; Pl => base_1+"jave" } ;
                     Ablat=> table { Sg => base_1+"je" ; Pl => base_1+"jash" }
                   } ;
          Def => table {
                   Nom => table { Sg => base_1+"ja" ;  Pl => base_1+"jat" } ;
                   Acc => table { Sg => base_1+"në" ;  Pl => base_1+"jat" } ;
