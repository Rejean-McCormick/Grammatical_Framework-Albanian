mkN196 : Str -> N ;
mkN196 base =
  case base of {
    base_1+base_2@?+"j"+base_3@(?+?)+"e" => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+base_2+"j"+base_3+"e" ; Pl => base_1+"j"+base_2+base_3+"e"   } ;
                         Acc   => table { Sg => base_1+base_2+"j"+base_3+"e" ; Pl => base_1+"j"+base_2+base_3+"e"   } ;
                         Dat   => table { Sg => base_1+base_2+"j"+base_3+"e" ; Pl => base_1+"j"+base_2+base_3+"eve" } ;
                         Ablat => table { Sg => base_1+base_2+"j"+base_3+"e" ; Pl => base_1+"j"+base_2+base_3+"esh" }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+base_2+"j"+base_3+"a"      ; Pl => (base_1+"j"+base_2+base_3+"e")+"t"  } ;
                       Acc   => table { Sg => (base_1+base_2+"j"+base_3+"e")+"n" ; Pl => (base_1+"j"+base_2+base_3+"e")+"t"  } ;
                       Dat   => table { Sg => (base_1+base_2+"j"+base_3)+"es"    ; Pl => base_1+"j"+base_2+base_3+"eve"       } ;
                       Ablat => table { Sg => (base_1+base_2+"j"+base_3)+"es"    ; Pl => base_1+"j"+base_2+base_3+"eve"       }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN196"
  } ;

