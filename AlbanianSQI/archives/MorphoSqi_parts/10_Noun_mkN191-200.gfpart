mkN195 : Str -> N ;
mkN195 base =
  case base of {
    base_1+"ua" => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"ua" ; Pl => base_1+"onj"   } ;
                         Acc   => table { Sg => base_1+"ua" ; Pl => base_1+"onj"   } ;
                         Dat   => table { Sg => base_1+"oi" ; Pl => base_1+"onjve" } ;
                         Ablat => table { Sg => base_1+"oi" ; Pl => base_1+"onjsh" }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+"oi"  ; Pl => base_1+"onjtë"  } ;
                       Acc   => table { Sg => base_1+"oin" ; Pl => base_1+"onjtë"  } ;
                       Dat   => table { Sg => base_1+"oit" ; Pl => base_1+"onjve"  } ;
