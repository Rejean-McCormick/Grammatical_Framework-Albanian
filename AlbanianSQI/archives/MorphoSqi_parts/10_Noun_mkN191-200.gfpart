                       Acc   => table { Sg => base_1+base_2+"un" ; Pl => base_1+base_2+"njtë"  } ;
                       Dat   => table { Sg => base_1+base_2+"ut" ; Pl => base_1+base_2+"njve"  } ;
                       Ablat => table { Sg => base_1+base_2+"ut" ; Pl => base_1+base_2+"njve"  }
                     }
            } ;
