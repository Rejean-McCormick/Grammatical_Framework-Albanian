mkN249 : Str -> N ;
mkN249 base =
  case base of {
    base_1+"ë" => lin N
      (let sg = base_1+"ë" ;
           pl = base_1+"a" ;
           plDef = base_1+"at"
       in {
        s = table {
          Indef => table {
            Nom   => table { Sg => sg ; Pl => pl } ;
            Acc   => table { Sg => sg ; Pl => pl } ;
            Dat   => table { Sg => base_1+"e" ; Pl => base_1+"ave" } ;
            Ablat => table { Sg => base_1+"e" ; Pl => base_1+"ash" }
          } ;
          Def => table {
            Nom   => table { Sg => base_1+"a" ; Pl => plDef } ;
            Acc   => table { Sg => base_1+"ën" ; Pl => plDef } ;
            Dat   => table { Sg => base_1+"ës" ; Pl => base_1+"ave" } ;
            Ablat => table { Sg => base_1+"ës" ; Pl => base_1+"ave" }
          }
        } ;
        g = Fem
      }) ;
    _ => error "Can't apply paradigm mkN249"
  } ;

mkN250 : Str -> N ;
mkN250 base =
  case base of {
    base_1@(?+?)+"e"+base_2 => lin N
      { s = table {
              Indef => table {
                         Nom => table { Sg => base_1+"e"+base_2 ; Pl => base_1+"a"+base_2+"ë" } ;
                         Acc => table { Sg => base_1+"e"+base_2 ; Pl => base_1+"a"+base_2+"ë" } ;
                         Dat => table { Sg => base_1+"e"+base_2+"i" ; Pl => base_1+"a"+base_2+"ëve" } ;
                         Ablat => table { Sg => base_1+"e"+base_2+"i" ; Pl => base_1+"a"+base_2+"ësh" }
                       } ;
              Def => table {
                       Nom => table { Sg => base_1+"e"+base_2+"i" ; Pl => base_1+"a"+base_2+"ët" } ;
                       Acc => table { Sg => base_1+"e"+base_2+"in" ; Pl => base_1+"a"+base_2+"ët" } ;
                       Dat => table { Sg => base_1+"e"+base_2+"it" ; Pl => base_1+"a"+base_2+"ëve" } ;
                       Ablat => table { Sg => base_1+"e"+base_2+"it" ; Pl => base_1+"a"+base_2+"ëve" }
                     }
            } ;
        g = Masc
      };
    _ => error "Can't apply paradigm mkN250"
  } ;