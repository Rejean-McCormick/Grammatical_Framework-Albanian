mkN241 : Str -> N ;
mkN241 base_1 =
  lin N
  (let sg = base_1+"r" ;
       pl = base_1+"j"
   in {
    s = table {
      Indef => table {
        Nom   => table { Sg => sg ; Pl => pl } ;
        Acc   => table { Sg => sg ; Pl => pl } ;
        Dat   => table { Sg => base_1+"ri" ; Pl => base_1+"jve" } ;
        Ablat => table { Sg => base_1+"ri" ; Pl => base_1+"jsh" }
      } ;
      Def => table {
        Nom   => table { Sg => base_1+"ri" ; Pl => base_1+"jtë" } ;
        Acc   => table { Sg => base_1+"rin" ; Pl => base_1+"jtë" } ;
        Dat   => table { Sg => base_1+"rit" ; Pl => base_1+"jve" } ;
        Ablat => table { Sg => base_1+"rit" ; Pl => base_1+"jve" }
      }
    } ;
    g = Masc
  }) ;

mkN242 : Str -> N ;
mkN242 base_1 =
  lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1 ; Pl => base_1 } ;
                     Acc   => table { Sg => base_1 ; Pl => base_1 } ;
                     Dat   => table { Sg => base_1+"i" ; Pl => base_1+"ve" } ;
                     Ablat => table { Sg => base_1+"i" ; Pl => base_1+"ish" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"i" ; Pl => base_1+"t" } ;
                   Acc   => table { Sg => base_1+"in" ; Pl => base_1+"t" } ;
                   Dat   => table { Sg => base_1+"it" ; Pl => base_1+"ve" } ;
                   Ablat => table { Sg => base_1+"it" ; Pl => base_1+"ve" }
                 }
        } ;
    g = Masc
  } ;

mkN243 : Str -> N ;
mkN243 base_1 =
  lin N
  (let pl = base_1+"j" ;
       plDef = base_1+"jtë"
   in {
    s = table {
      Indef => table {
        Nom   => table { Sg => base_1 ; Pl => pl } ;
        Acc   => table { Sg => base_1 ; Pl => pl } ;
        Dat   => table { Sg => base_1+"i" ; Pl => base_1+"jve" } ;
        Ablat => table { Sg => base_1+"i" ; Pl => base_1+"jsh" }
      } ;
      Def => table {
        Nom   => table { Sg => base_1+"i" ; Pl => plDef } ;
        Acc   => table { Sg => base_1+"in" ; Pl => plDef } ;
        Dat   => table { Sg => base_1+"it" ; Pl => base_1+"jve" } ;
        Ablat => table { Sg => base_1+"it" ; Pl => base_1+"jve" }
      }
    } ;
    g = Masc
  }) ;

mkN244 : Str -> N ;
mkN244 base =
  case base of {
    "b"+base_1+"nor" => lin N
      (let sg = "b"+base_1+"nor" ;
           pl = "b"+base_1+"norë" ;
           sgDef = "b"+base_1+"nori" ;
           plDef = "b"+base_1+"norët"
       in {
        s = table {
          Indef => table {
            Nom   => table { Sg => sg ; Pl => pl } ;
            Acc   => table { Sg => sg ; Pl => pl } ;
            Dat   => table { Sg => sg+"i" ; Pl => "b"+base_1+"norëve" } ;
            Ablat => table { Sg => sg+"i" ; Pl => "b"+base_1+"norësh" }
          } ;
          Def => table {
            Nom   => table { Sg => sgDef ; Pl => plDef } ;
            Acc   => table { Sg => "b"+base_1+"norin" ; Pl => plDef } ;
            Dat   => table { Sg => "b"+base_1+"norit" ; Pl => "b"+base_1+"norëve" } ;
            Ablat => table { Sg => "b"+base_1+"norit" ; Pl => "b"+base_1+"norëve" }
          }
        } ;
        g = Masc
      }) ;
    _ => error "Can't apply paradigm mkN244"
  } ;

