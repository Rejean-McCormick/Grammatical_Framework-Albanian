                       Acc   => table { Sg => base_1+"u"+base_2+"in" ; Pl => base_1+base_2+"njt"   } ;
                       Dat   => table { Sg => base_1+"u"+base_2+"it" ; Pl => base_1+base_2+"njve"  } ;
                       Ablat => table { Sg => base_1+"u"+base_2+"it" ; Pl => base_1+base_2+"njve"  }
