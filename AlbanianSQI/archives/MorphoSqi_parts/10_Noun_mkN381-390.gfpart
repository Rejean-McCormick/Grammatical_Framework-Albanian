mkN389 base =
  case base of {
    base_1+"n" => lin N
      let
        sgInd = base_1+"n" ;
        plInd = base_1+"j" ;
      in {
        s = table {
          Indef => table {
            Nom => table { Sg => sgInd ; Pl => plInd } ;
            Acc => table { Sg => sgInd ; Pl => plInd } ;
            Dat => table { Sg => base_1+"ni" ; Pl => plInd+"ve" } ;
            Ablat => table { Sg => base_1+"ni" ; Pl => plInd+"sh" }
          } ;
          Def => table {
            Nom => table { Sg => base_1+"ni" ; Pl => plInd+"të" } ;
            Acc => table { Sg => base_1+"nin" ; Pl => plInd+"të" } ;
            Dat => table { Sg => base_1+"nit" ; Pl => plInd+"ve" } ;
            Ablat => table { Sg => base_1+"nit" ; Pl => plInd+"ve" }
          }
        } ;
        g = Masc
      } ;
    _ => error "Can't apply paradigm mkN389"
  } ;

mkN390 : Str -> N ;
mkN390 base =
  case base of {
    base_1+"ke" => lin N
      let
        sgInd = base_1+"ke" ;
        plInd = base_1+"qe" ;
      in {
        s = table {
          Indef => table {
            Nom => table { Sg => sgInd ; Pl => plInd } ;
            Acc => table { Sg => sgInd ; Pl => plInd } ;
            Dat => table { Sg => sgInd+"je" ; Pl => plInd+"ve" } ;
            Ablat => table { Sg => sgInd+"je" ; Pl => plInd+"sh" }
          } ;
          Def => table {
            Nom => table { Sg => base_1+"ku" ; Pl => plInd+"t" } ;
            Acc => table { Sg => base_1+"kun" ; Pl => plInd+"t" } ;
            Dat => table { Sg => base_1+"kut" ; Pl => plInd+"ve" } ;
            Ablat => table { Sg => base_1+"kut" ; Pl => plInd+"ve" }
          }
        } ;
        g = Fem
      } ;
    _ => error "Can't apply paradigm mkN390"
  } ;