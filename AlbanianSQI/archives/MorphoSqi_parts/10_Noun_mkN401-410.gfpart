mkN408 base =
  case base of {
    base_1+"ë" => lin N
      (let sg = base_1+"ë" ; pl = base_1+"ë" ; defPl = base_1+"ët" in {
        s = table {
          Indef => table {
            Nom   => table { Sg => sg ; Pl => pl } ;
            Acc   => table { Sg => sg ; Pl => pl } ;
            Dat   => table { Sg => base_1+"e" ; Pl => base_1+"ëve" } ;
            Ablat => table { Sg => base_1+"e" ; Pl => base_1+"ësh" }
          } ;
          Def => table {
            Nom   => table { Sg => base_1+"a" ; Pl => defPl } ;
            Acc   => table { Sg => base_1+"ën" ; Pl => defPl } ;
