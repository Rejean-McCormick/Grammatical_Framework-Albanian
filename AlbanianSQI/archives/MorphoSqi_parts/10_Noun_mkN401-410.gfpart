mkN407 base =
  case base of {
    base_1+"ë" => lin N
      (let sg = base_1+"ë" ; pl = base_1+"e" ; defPl = base_1+"et" in {
        s = table {
          Indef => table {
            Nom   => table { Sg => sg ; Pl => pl } ;
            Acc   => table { Sg => sg ; Pl => pl } ;
            Dat   => table { Sg => base_1+"e" ; Pl => base_1+"eve" } ;
            Ablat => table { Sg => base_1+"e" ; Pl => base_1+"esh" }
          } ;
          Def => table {
            Nom   => table { Sg => base_1+"a" ; Pl => defPl } ;
            Acc   => table { Sg => base_1+"ën" ; Pl => defPl } ;
            Dat   => table { Sg => base_1+"ës" ; Pl => base_1+"eve" } ;
            Ablat => table { Sg => base_1+"ës" ; Pl => base_1+"eve" }
          }
        } ;
        g = Fem
      });
