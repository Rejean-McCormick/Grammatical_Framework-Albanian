mkN409 : Str -> N ;
mkN409 base =
  case base of {
    base_1+"kë" => lin N
      (let sg = base_1+"kë" ;
           pl = base_1+"qe" ;
           defSg = base_1+"ka" ;
           defPl = base_1+"qet"
       in {
        s = table {
          Indef => table {
            Nom   => table { Sg => sg ; Pl => pl } ;
            Acc   => table { Sg => sg ; Pl => pl } ;
            Dat   => table { Sg => base_1+"ke" ; Pl => base_1+"qeve" } ;
            Ablat => table { Sg => base_1+"ke" ; Pl => base_1+"qesh" }
          } ;
          Def => table {
            Nom   => table { Sg => defSg ; Pl => defPl } ;
            Acc   => table { Sg => base_1+"kan" ; Pl => defPl } ;
            Dat   => table { Sg => base_1+"kës" ; Pl => base_1+"qeve" } ;
            Ablat => table { Sg => base_1+"kës" ; Pl => base_1+"qeve" }
          }
        } ;
        g = Fem
      });
    _ => error "Can't apply paradigm mkN409"
  } ;

mkN410 : Str -> N ;
mkN410 base_1 =
  case base_1 of {
    stem+"k" => mkN410_core base_1 "u" ;
    stem+"g" => mkN410_core base_1 "u" ;
    stem+"h" => mkN410_core base_1 "u" ;
    _        => mkN410_core base_1 "i"
  }
  where {
    mkN410_core : Str -> Str -> N = \b,obl ->
      lin N
      (let pl = b+"ë" in {
        s = table {
          Indef => table {
            Nom   => table { Sg => b ; Pl => pl } ;
            Acc   => table { Sg => b ; Pl => pl } ;
            Dat   => table { Sg => b+obl ; Pl => b+"ëve" } ;
            Ablat => table { Sg => b+obl ; Pl => b+"ësh" }
          } ;
          Def => table {
            Nom   => table { Sg => b+obl ; Pl => b+"ët" } ;
            Acc   => table { Sg => b+obl+"n" ; Pl => b+"ët" } ;
            Dat   => table { Sg => b+obl+"t" ; Pl => b+"ëve" } ;
            Ablat => table { Sg => b+obl+"t" ; Pl => b+"ëve" }
          }
        } ;
        g = Masc
      });
  } ;