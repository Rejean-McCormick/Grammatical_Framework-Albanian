mkN428 : Str -> N ;
mkN428 base =
  case base of {
    base_1+"ë"+base_2@? => lin N
      (let stem = base_1+base_2 ; pl = stem+"a" in {
        s = table {
          Indef => table {
            Nom   => table { Sg => base_1+"ë"+base_2 ; Pl => pl } ;
            Acc   => table { Sg => base_1+"ë"+base_2 ; Pl => pl } ;
            Dat   => table { Sg => stem+"e" ; Pl => pl+"ve" } ;
            Ablat => table { Sg => stem+"e" ; Pl => pl+"sh" }
          } ;
          Def => table {
            Nom   => table { Sg => stem+"a" ; Pl => pl+"t" } ;
            Acc   => table { Sg => stem+"ën" ; Pl => pl+"t" } ;
            Dat   => table { Sg => stem+"ës" ; Pl => pl+"ve" } ;
            Ablat => table { Sg => stem+"ës" ; Pl => pl+"ve" }
          }
        } ;
        g = Masc
      }) ;
    _ => error "Can't apply paradigm mkN428"
  } ;

mkN429 : Str -> N ;
mkN429 base_1 =
  lin N
  (let pl = base_1+"j" ; defSg = base_1+"ni" ; defPl = base_1+"jtë" in {
    s = table {
      Indef => table {
        Nom   => table { Sg => base_1 ; Pl => pl } ;
        Acc   => table { Sg => base_1 ; Pl => pl } ;
        Dat   => table { Sg => base_1+"i" ; Pl => pl+"ve" } ;
        Ablat => table { Sg => base_1+"i" ; Pl => pl+"sh" }
      } ;
      Def => table {
        Nom   => table { Sg => defSg ; Pl => defPl } ;
        Acc   => table { Sg => defSg+"n" ; Pl => defPl } ;
        Dat   => table { Sg => defSg+"t" ; Pl => pl+"ve" } ;
        Ablat => table { Sg => defSg+"t" ; Pl => pl+"ve" }
      }
    } ;
    g = Masc
  }) ;

mkN430 : Str -> N ;
mkN430 base =
  case base of {
    base_1+"ë"+base_2@? => lin N
      (let stem = base_1+base_2 ; pl = stem+"a" in {
        s = table {
          Indef => table {
            Nom   => table { Sg => base_1+"ë"+base_2 ; Pl => pl } ;
            Acc   => table { Sg => base_1+"ë"+base_2 ; Pl => pl } ;
            Dat   => table { Sg => stem+"i" ; Pl => pl+"ve" } ;
            Ablat => table { Sg => stem+"i" ; Pl => pl+"sh" }
          } ;
          Def => table {
            Nom   => table { Sg => stem+"i" ; Pl => pl+"t" } ;  -- = stem+"at"
            Acc   => table { Sg => stem+"in" ; Pl => pl+"t" } ;
            Dat   => table { Sg => stem+"it" ; Pl => pl+"ve" } ;
            Ablat => table { Sg => stem+"it" ; Pl => pl+"ve" }
          }
        } ;
        g = Fem
      }) ;
    _ => error "Can't apply paradigm mkN430"
  } ;