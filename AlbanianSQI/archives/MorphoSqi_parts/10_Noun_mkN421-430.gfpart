        Indef => table {
          Nom   => table { Sg => base_1 ; Pl => pl } ;
          Acc   => table { Sg => base_1 ; Pl => pl } ;
          Dat   => table { Sg => base_1+obl ; Pl => pl+"ve" } ;
          Ablat => table { Sg => base_1+obl ; Pl => pl+"sh" }
        } ;
        Def => table {
          Nom   => table { Sg => base_1+obl ; Pl => pl+"t" } ;
          Acc   => table { Sg => base_1+obl+"n" ; Pl => pl+"t" } ;
          Dat   => table { Sg => base_1+obl+"t" ; Pl => pl+"ve" } ;
          Ablat => table { Sg => base_1+obl+"t" ; Pl => pl+"ve" }
        }
      } ;
      g = Fem
    })
