mkN477 : Str -> N ;
mkN477 base =
  case base of {
    base_1+"ë"+base_2@? => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"ë"+base_2 ; Pl => base_1+base_2+"a"   } ;
                         Acc   => table { Sg => base_1+"ë"+base_2 ; Pl => base_1+base_2+"a"   } ;
                         Dat   => table { Sg => base_1+base_2+"e"  ; Pl => base_1+base_2+"ave" } ;
                         Ablat => table { Sg => base_1+base_2+"e"  ; Pl => base_1+base_2+"ash" }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+base_2+"a"  ; Pl => base_1+base_2+"at"  } ;
                       Acc   => table { Sg => base_1+base_2+"ën" ; Pl => base_1+base_2+"at"  } ;
                       Dat   => table { Sg => base_1+base_2+"ës" ; Pl => base_1+base_2+"ave" } ;
                       Ablat => table { Sg => base_1+base_2+"ës" ; Pl => base_1+base_2+"ave" }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN477"
  } ;

mkN478 : Str -> N ;
mkN478 base =
  case base of {
    "lu"+base_1+"neshë" => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => "lu"+base_1+"neshë" ; Pl => "lu"+base_1+"nesha"  } ;
                         Acc   => table { Sg => "lu"+base_1+"neshë" ; Pl => "lu"+base_1+"nesha"  } ;
                         Dat   => table { Sg => "lu"+base_1+"neshe" ; Pl => "lu"+base_1+"neshave" } ;
                         Ablat => table { Sg => "lu"+base_1+"neshe" ; Pl => "lu"+base_1+"neshash" }
                       } ;
              Def => table {
                       Nom   => table { Sg => "lu"+base_1+"nesha"  ; Pl => "lu"+base_1+"neshat"  } ;
                       Acc   => table { Sg => "lu"+base_1+"neshën" ; Pl => "lu"+base_1+"neshat"  } ;
                       Dat   => table { Sg => "lu"+base_1+"neshës" ; Pl => "lu"+base_1+"neshave" } ;
                       Ablat => table { Sg => "lu"+base_1+"neshës" ; Pl => "lu"+base_1+"neshave" }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN478"
  } ;

