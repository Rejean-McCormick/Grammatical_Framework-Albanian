mkN471 : Str -> N ;
mkN471 base_1 =
  lin N
  { s = table {
          Indef => table {
                     Nom   => table { Sg => base_1      ; Pl => base_1+"e"   } ;
                     Acc   => table { Sg => base_1      ; Pl => base_1+"e"   } ;
                     Dat   => table { Sg => base_1+"i"  ; Pl => base_1+"eve" } ;
                     Ablat => table { Sg => base_1+"i"  ; Pl => base_1+"esh" }
                   } ;
          Def => table {
                   Nom   => table { Sg => base_1+"i"  ; Pl => base_1+"et"  } ;
                   Acc   => table { Sg => base_1+"in" ; Pl => base_1+"et"  } ;
                   Dat   => table { Sg => base_1+"it" ; Pl => base_1+"eve" } ;
                   Ablat => table { Sg => base_1+"it" ; Pl => base_1+"eve" }
                 }
        } ;
    g = Masc
  } ;

mkN472 : Str -> N ;
mkN472 base =
  case base of {
    base_1+"e" => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"e"    ; Pl => base_1+"e"    } ;
                         Acc   => table { Sg => base_1+"e"    ; Pl => base_1+"e"    } ;
                         Dat   => table { Sg => base_1+"eje"  ; Pl => base_1+"eve"  } ;
                         Ablat => table { Sg => base_1+"eje"  ; Pl => base_1+"esh"  }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+"ja" ; Pl => base_1+"et"  } ;
                       Acc   => table { Sg => base_1+"en" ; Pl => base_1+"et"  } ;
                       Dat   => table { Sg => base_1+"es" ; Pl => base_1+"eve" } ;
                       Ablat => table { Sg => base_1+"es" ; Pl => base_1+"eve" }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN472"
  } ;

mkN473 : Str -> N ;
mkN473 base =
  case base of {
    base_1+"ë" => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+"ë" ; Pl => base_1+"ee"   } ;
                         Acc   => table { Sg => base_1+"ë" ; Pl => base_1+"ee"   } ;
                         Dat   => table { Sg => base_1+"e" ; Pl => base_1+"eeve" } ;
                         Ablat => table { Sg => base_1+"e" ; Pl => base_1+"eesh" }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+"a"  ; Pl => base_1+"eet"  } ;
                       Acc   => table { Sg => base_1+"ën" ; Pl => base_1+"eet"  } ;
                       Dat   => table { Sg => base_1+"ës" ; Pl => base_1+"eeve" } ;
                       Ablat => table { Sg => base_1+"ës" ; Pl => base_1+"eeve" }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN473"
  } ;

mkN474 : Str -> N ;
mkN474 base =
  case base of {
    base_1+base_2@(?+?+?+?+?+?)+"e" => lin N
      { s = table {
              Indef => table {
                         Nom   => table { Sg => base_1+base_2+"e"   ; Pl => nonExist } ;
                         Acc   => table { Sg => base_1+base_2+"e"   ; Pl => nonExist } ;
                         Dat   => table { Sg => base_1+base_2+"eje" ; Pl => nonExist } ;
                         Ablat => table { Sg => base_1+base_2+"eje" ; Pl => nonExist }
                       } ;
              Def => table {
                       Nom   => table { Sg => base_1+base_2+"ja" ; Pl => nonExist } ;
                       Acc   => table { Sg => base_1+base_2+"en" ; Pl => nonExist } ;
                       Dat   => table { Sg => base_1+base_2+"es" ; Pl => nonExist } ;
                       Ablat => table { Sg => base_1+base_2+"es" ; Pl => nonExist }
                     }
            } ;
        g = Fem
      };
    _ => error "Can't apply paradigm mkN474"
  } ;

