                   Acc   => table { Sg => base_1+"un" ; Pl => base_1+"ilirologët"   } ;
                   Dat   => table { Sg => base_1+"ut" ; Pl => base_1+"ilirologëve"  } ;
                   Ablat => table { Sg => base_1+"ut" ; Pl => base_1+"ilirologëve"  }
                 }
        } ;
