oper
  removeFinalA : Str -> Str = \s ->
    case s of { st + "a" => st ; _ => s } ;

  -- Past definite 3sg is -u after velars or after i/a/e; else -i.
  aor3sg : Str -> Str = \st ->
    case st of {
      _ + "k" => st + "u" ;
      _ + "g" => st + "u" ;
      _ + "h" => st + "u" ;
      _ + "i" => st + "u" ;
      _ + "a" => st + "u" ;
      _ + "e" => st + "u" ;
      _ => st + "i"
    } ;

  mkAorTable : Str -> table Number (table Person Str) = \aor1 ->
    let st = removeFinalA aor1 in
    table {
      Sg => table { P1 => aor1 ; P2 => st + "e" ; P3 => aor3sg st } ;
      Pl => table { P1 => st + "ëm" ; P2 => st + "ët" ; P3 => st + "ën" }
    } ;

  mkPerfTable : Str -> table Number (table Person Str) = \pple ->
    table {
      Sg => table { P1 => "kam " + pple ; P2 => "ke " + pple ; P3 => "ka " + pple } ;
      Pl => table { P1 => "kemi " + pple ; P2 => "keni " + pple ; P3 => "kanë " + pple }
    } ;

  -- Conservative consonant-stem present: 1/2/3sg = citation; pl = +im/+ni/+in
  mkPresCons : Str -> table Number (table Person Str) = \base ->
    table {
      Sg => table { P1 => base ; P2 => base ; P3 => base } ;
      Pl => table { P1 => base + "im" ; P2 => base + "ni" ; P3 => base + "in" }
    } ;

  -- -j present class (as you used elsewhere)
  mkPresJ : Str -> table Number (table Person Str) = \stem ->
    table {
      Sg => table { P1 => stem + "j" ; P2 => stem + "n" ; P3 => stem + "n" } ;
      Pl => table { P1 => stem + "jmë" ; P2 => stem + "ni" ; P3 => stem + "jnë" }
    } ;

  mkImperfCons : Str -> table Number (table Person Str) = \st ->
    table {
      Sg => table { P1 => st + "ja" ; P2 => st + "je" ; P3 => st + "te" } ;
      Pl => table { P1 => st + "nim" ; P2 => st + "nit" ; P3 => st + "nin" }
    } ;

  mkImperativeBare : Str -> table Number Str = \st ->
    table { Sg => st ; Pl => st + "ni" } ;

  removeFinalE : Str -> Str = \s ->
    case s of { st + "e" => st ; _ => s } ;

  shortPple : Str -> Str = \pple ->
    case pple of {
      st + "r" => st ;
      st + "ë" => st ;
      _ => pple
    } ;

  mkAdmPres : Str -> table Number (table Person Str) = \pple ->
    let sh = shortPple pple in
    table {
      Sg => table { P1 => sh + "kam" ; P2 => sh + "ke" ; P3 => sh + "ka" } ;
      Pl => table { P1 => sh + "kemi" ; P2 => sh + "keni" ; P3 => sh + "kan" }
    } ;

  mkAdmImperf : Str -> table Number (table Person Str) = \pple ->
    let sh = shortPple pple in
    table {
      Sg => table { P1 => sh + "kësha" ; P2 => sh + "këshe" ; P3 => sh + "kësh" } ;
      Pl => table { P1 => sh + "këshim" ; P2 => sh + "këshit" ; P3 => sh + "këshin" }
    } ;

  mkOptFromAor1 : Str -> table Number (table Person Str) = \aor1 ->
    let st = removeFinalA aor1 in
    table {
      Sg => table { P1 => st + "fsha" ; P2 => st + "fsh" ; P3 => st + "ftë" } ;
      Pl => table { P1 => st + "fshim" ; P2 => st + "fshi" ; P3 => st + "fshin" }
    } ;

  mkPerfOpt : Str -> table Number (table Person Str) = \pple ->
    table {
      Sg => table { P1 => "paça " + pple ; P2 => "paç " + pple ; P3 => "pastë " + pple } ;
      Pl => table { P1 => "paçim " + pple ; P2 => "paçi " + pple ; P3 => "paçin " + pple }
    } ;

-- =========================
-- UPDATED PARADIGMS 51..60
-- =========================

mkV051 : Str -> V ;
mkV051 base =
  case base of {
    base_1 + "je" + base_2@? + "r" =>
      let pres1 = base_1 + "je" + base_2 + "r" ;
          aor1  = base_1 + "o"  + base_2 + "a" ;
          pple  = base_1 + "je" + base_2 + "rë" ;
          impSt = base_1 + "i"  + base_2 + "r"
      in lin V {
        Indicative = table {
          Pres      => mkPresCons pres1 ;
          Past      => mkPerfTable pple ;
          Aorist    => mkAorTable aor1 ;
          Imperfect => mkImperfCons impSt
        } ;
        Imperative = mkImperativeBare impSt ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV051"
  } ;

mkV052 : Str -> V ;
mkV052 base =
  case base of {
    base_1 + "r" + base_2@? =>
      let pres1 = base_1 + "r" + base_2 ;
          aor1  = pres1 ;               -- as in your original
          pple  = base_1 + "n" + base_2 ;
          impSt = pres1
      in lin V {
        Indicative = table {
          Pres      => mkPresCons pres1 ;
          Past      => mkPerfTable pple ;
          Aorist    => mkAorTable aor1 ;
          Imperfect => mkImperfCons impSt
        } ;
        Imperative = mkImperativeBare impSt ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
        imperf_admirative = mkAdmImperf pple
      } ;
    _ => error "Can't apply paradigm mkV052"
  } ;

