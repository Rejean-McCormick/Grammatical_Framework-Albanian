      } ;
    _ => error "Can't apply paradigm mkV060"
  } ;mkV051 : Str -> V ;
mkV051 base =
  case base of {
    base_1+"je"+base_2@?+"r" =>
      let
        presS : Str = base_1+"je"+base_2+"r" ;         -- e.g. nxjerr
        pres2plS : Str = base_1+"i"+base_2+"r" ;       -- umlauted stem often used in 2pl/imp (heuristic)
        aorS : Str = base_1+"o"+base_2 ;               -- e.g. nxor-
        impS : Str = base_1+"i"+base_2+"r" ;           -- e.g. nxirr-
        part : Str = base_1+"je"+base_2+"rë" ;         -- e.g. nxjerrë
        partStem : Str = base_1+"je"+base_2+"r" ;      -- drop ë
        optBase : Str = aorS ;                         -- optative built on past definite stem
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table {
              P1 => presS ;
              P2 => presS ;
              P3 => presS
            } ;
            Pl => table {
              P1 => presS+"im" ;
              P2 => pres2plS+"ni" ;
              P3 => presS+"in"
            }
          } ;
          Past => table {  -- perfect: kam + participle
            Sg => table {
              P1 => "kam "+part ;
              P2 => "ke "+part ;
              P3 => "ka "+part
            } ;
            Pl => table {
              P1 => "kemi "+part ;
              P2 => "keni "+part ;
              P3 => "kanë "+part
            }
          } ;
          Aorist => table {  -- past definite
            Sg => table {
              P1 => aorS+"a" ;
              P2 => aorS+"e" ;
              P3 => aorS+"i"
            } ;
            Pl => table {
              P1 => aorS+"ëm" ;
              P2 => aorS+"ët" ;
              P3 => aorS+"ën"
            }
          } ;
          Imperfect => table {
            Sg => table {
              P1 => impS+"ja" ;
              P2 => impS+"je" ;
              P3 => impS+"te"
            } ;
            Pl => table {
              P1 => impS+"nim" ;
              P2 => impS+"nit" ;
              P3 => impS+"nin"
            }
          }
        } ;
        Imperative = table {
          Sg => pres2plS ;          -- heuristic: nxirr!
          Pl => pres2plS+"ni"       -- nxirrni!
        } ;
        participle = part ;

        pres_optative = table {
          Sg => table {
            P1 => optSh+"a" ;
            P2 => optSh ;
            P3 => optBase+"të"
          } ;
          Pl => table {
            P1 => optSh+"im" ;
            P2 => optSh+"i" ;
            P3 => optSh+"in"
          }
        } ;

        perf_optative = table {     -- optative of kam + participle
          Sg => table {
            P1 => "paça "+part ;
            P2 => "paç "+part ;
            P3 => "pastë "+part
          } ;
          Pl => table {
            P1 => "paçim "+part ;
            P2 => "paçi "+part ;
            P3 => "paçin "+part
          }
        } ;

        pres_admirative = table {   -- participle-stem + appended present-of-kam pieces
          Sg => table {
            P1 => partStem+"kam" ;
            P2 => partStem+"ke" ;
            P3 => partStem+"ka"
          } ;
          Pl => table {
            P1 => partStem+"kemi" ;
            P2 => partStem+"keni" ;
            P3 => partStem+"kan"
          }
        } ;

        imperf_admirative = table { -- participle-stem + kësha-series
          Sg => table {
            P1 => partStem+"kësha" ;
            P2 => partStem+"këshe" ;
            P3 => partStem+"kësh"
          } ;
          Pl => table {
            P1 => partStem+"këshim" ;
            P2 => partStem+"këshit" ;
            P3 => partStem+"këshin"
          }
        }
      } ;
    _ => error "Can't apply paradigm mkV051"
  } ;

mkV052 : Str -> V ;
mkV052 base =
  case base of {
    base_1+"r"+base_2@? =>
      let
        presS : Str = base_1+"r"+base_2 ;
        aorS : Str = presS ;
        impS : Str = presS ;
        part : Str = base_1+"n"+base_2 ;
        partStem : Str = part ;
        optBase : Str = aorS ;
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => presS ; P2 => presS ; P3 => presS } ;
            Pl => table { P1 => presS+"im" ; P2 => presS+"ni" ; P3 => presS+"in" }
          } ;
          Past => table {
            Sg => table { P1 => "kam "+part ; P2 => "ke "+part ; P3 => "ka "+part } ;
            Pl => table { P1 => "kemi "+part ; P2 => "keni "+part ; P3 => "kanë "+part }
          } ;
          Aorist => table {
            Sg => table { P1 => aorS+"a" ; P2 => aorS+"e" ; P3 => aorS+"i" } ;
            Pl => table { P1 => aorS+"ëm" ; P2 => aorS+"ët" ; P3 => aorS+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => impS+"ja" ; P2 => impS+"je" ; P3 => impS+"te" } ;
            Pl => table { P1 => impS+"nim" ; P2 => impS+"nit" ; P3 => impS+"nin" }
          }
        } ;
        Imperative = table { Sg => presS ; Pl => presS+"ni" } ;
        participle = part ;

        pres_optative = table {
          Sg => table { P1 => optSh+"a" ; P2 => optSh ; P3 => optBase+"të" } ;
          Pl => table { P1 => optSh+"im" ; P2 => optSh+"i" ; P3 => optSh+"in" }
        } ;
        perf_optative = table {
          Sg => table { P1 => "paça "+part ; P2 => "paç "+part ; P3 => "pastë "+part } ;
          Pl => table { P1 => "paçim "+part ; P2 => "paçi "+part ; P3 => "paçin "+part }
        } ;
        pres_admirative = table {
          Sg => table { P1 => partStem+"kam" ; P2 => partStem+"ke" ; P3 => partStem+"ka" } ;
          Pl => table { P1 => partStem+"kemi" ; P2 => partStem+"keni" ; P3 => partStem+"kan" }
        } ;
        imperf_admirative = table {
          Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
          Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV052"
  } ;

mkV053 : Str -> V ;
mkV053 base =
  case base of {
    base_1+"i"+base_2@(?+?) =>
      let
        presS : Str = base_1+"i"+base_2 ;
        aorS  : Str = base_1+"o"+base_2 ;
        impS  : Str = presS ;
        part  : Str = base_1+"i"+base_2+"ur" ;
        partStem : Str = base_1+"i"+base_2+"u" ;
        optBase : Str = aorS ;
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => presS ; P2 => presS ; P3 => presS } ;
            Pl => table { P1 => presS+"im" ; P2 => presS+"ni" ; P3 => presS+"in" }
          } ;
          Past => table {
            Sg => table { P1 => "kam "+part ; P2 => "ke "+part ; P3 => "ka "+part } ;
            Pl => table { P1 => "kemi "+part ; P2 => "keni "+part ; P3 => "kanë "+part }
          } ;
          Aorist => table {
            Sg => table { P1 => aorS+"a" ; P2 => aorS+"e" ; P3 => aorS+"i" } ;
            Pl => table { P1 => aorS+"ëm" ; P2 => aorS+"ët" ; P3 => aorS+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => impS+"ja" ; P2 => impS+"je" ; P3 => impS+"te" } ;
            Pl => table { P1 => impS+"nim" ; P2 => impS+"nit" ; P3 => impS+"nin" }
          }
        } ;
        Imperative = table { Sg => presS ; Pl => presS+"ni" } ;
        participle = part ;

        pres_optative = table {
          Sg => table { P1 => optSh+"a" ; P2 => optSh ; P3 => optBase+"të" } ;
          Pl => table { P1 => optSh+"im" ; P2 => optSh+"i" ; P3 => optSh+"in" }
        } ;
        perf_optative = table {
          Sg => table { P1 => "paça "+part ; P2 => "paç "+part ; P3 => "pastë "+part } ;
          Pl => table { P1 => "paçim "+part ; P2 => "paçi "+part ; P3 => "paçin "+part }
        } ;
        pres_admirative = table {
          Sg => table { P1 => partStem+"kam" ; P2 => partStem+"ke" ; P3 => partStem+"ka" } ;
          Pl => table { P1 => partStem+"kemi" ; P2 => partStem+"keni" ; P3 => partStem+"kan" }
        } ;
        imperf_admirative = table {
          Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
          Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV053"
  } ;

mkV054 : Str -> V ;
mkV054 base =
  case base of {
    base_1+"j" =>
      let
        pres1 : Str = base_1+"j" ;
        pres23 : Str = base_1+"n" ;       -- bëj-type present
        pres1pl : Str = base_1+"jmë" ;
        pres2pl : Str = base_1+"ni" ;
        pres3pl : Str = base_1+"jnë" ;
        aorS : Str = base_1+"jt" ;
        impS : Str = base_1 ;             -- heuristic stem for imperfect
        part : Str = base_1+"rë" ;
        partStem : Str = base_1+"r" ;
        optBase : Str = aorS ;
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => pres1 ; P2 => pres23 ; P3 => pres23 } ;
            Pl => table { P1 => pres1pl ; P2 => pres2pl ; P3 => pres3pl }
          } ;
          Past => table {
            Sg => table { P1 => "kam "+part ; P2 => "ke "+part ; P3 => "ka "+part } ;
            Pl => table { P1 => "kemi "+part ; P2 => "keni "+part ; P3 => "kanë "+part }
          } ;
          Aorist => table {
            Sg => table { P1 => aorS+"a" ; P2 => aorS+"e" ; P3 => aorS+"i" } ;
            Pl => table { P1 => aorS+"ëm" ; P2 => aorS+"ët" ; P3 => aorS+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => impS+"ja" ; P2 => impS+"je" ; P3 => impS+"te" } ;
            Pl => table { P1 => impS+"nim" ; P2 => impS+"nit" ; P3 => impS+"nin" }
          }
        } ;
        Imperative = table { Sg => partStem ; Pl => pres2pl } ;
        participle = part ;

        pres_optative = table {
          Sg => table { P1 => optSh+"a" ; P2 => optSh ; P3 => optBase+"të" } ;
          Pl => table { P1 => optSh+"im" ; P2 => optSh+"i" ; P3 => optSh+"in" }
        } ;
        perf_optative = table {
          Sg => table { P1 => "paça "+part ; P2 => "paç "+part ; P3 => "pastë "+part } ;
          Pl => table { P1 => "paçim "+part ; P2 => "paçi "+part ; P3 => "paçin "+part }
        } ;
        pres_admirative = table {
          Sg => table { P1 => partStem+"kam" ; P2 => partStem+"ke" ; P3 => partStem+"ka" } ;
          Pl => table { P1 => partStem+"kemi" ; P2 => partStem+"keni" ; P3 => partStem+"kan" }
        } ;
        imperf_admirative = table {
          Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
          Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV054"
  } ;

mkV055 : Str -> V ;
mkV055 base =
  case base of {
    base_1+"em" =>
      let
        pres1 : Str = base_1+"em" ;
        pres2 : Str = base_1+"esh" ;
        pres3 : Str = base_1+"et" ;
        pres1pl : Str = base_1+"emi" ;
        pres2pl : Str = base_1+"eni" ;
        pres3pl : Str = base_1+"en" ;
        aorS : Str = base_1 ;              -- since 1sg aorist in original is base_1+"a"
        impS : Str = base_1+"e" ;          -- heuristic (cf. lahesha-type)
        part : Str = base_1+"ë" ;
        partStem : Str = base_1 ;
        optBase : Str = aorS ;
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => pres1 ; P2 => pres2 ; P3 => pres3 } ;
            Pl => table { P1 => pres1pl ; P2 => pres2pl ; P3 => pres3pl }
          } ;
          Past => table {
            Sg => table { P1 => "kam "+part ; P2 => "ke "+part ; P3 => "ka "+part } ;
            Pl => table { P1 => "kemi "+part ; P2 => "keni "+part ; P3 => "kanë "+part }
          } ;
          Aorist => table {
            Sg => table { P1 => aorS+"a" ; P2 => aorS+"e" ; P3 => aorS+"i" } ;
            Pl => table { P1 => aorS+"ëm" ; P2 => aorS+"ët" ; P3 => aorS+"ën" }
          } ;
          Imperfect => table {
            Sg => table { P1 => impS+"sha" ; P2 => impS+"she" ; P3 => impS+"j" } ;
            Pl => table { P1 => impS+"shim" ; P2 => impS+"shit" ; P3 => impS+"shin" }
          }
        } ;
        Imperative = table { Sg => partStem ; Pl => pres2pl } ;
        participle = part ;

        pres_optative = table {
          Sg => table { P1 => optSh+"a" ; P2 => optSh ; P3 => optBase+"të" } ;
          Pl => table { P1 => optSh+"im" ; P2 => optSh+"i" ; P3 => optSh+"in" }
        } ;
        perf_optative = table {
          Sg => table { P1 => "paça "+part ; P2 => "paç "+part ; P3 => "pastë "+part } ;
          Pl => table { P1 => "paçim "+part ; P2 => "paçi "+part ; P3 => "paçin "+part }
        } ;
        pres_admirative = table {
          Sg => table { P1 => partStem+"kam" ; P2 => partStem+"ke" ; P3 => partStem+"ka" } ;
          Pl => table { P1 => partStem+"kemi" ; P2 => partStem+"keni" ; P3 => partStem+"kan" }
        } ;
        imperf_admirative = table {
          Sg => table { P1 => partStem+"kësha" ; P2 => partStem+"këshe" ; P3 => partStem+"kësh" } ;
          Pl => table { P1 => partStem+"këshim" ; P2 => partStem+"këshit" ; P3 => partStem+"këshin" }
        }
      } ;
    _ => error "Can't apply paradigm mkV055"
  } ;

