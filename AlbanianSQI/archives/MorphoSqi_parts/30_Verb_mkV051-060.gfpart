mkV060 : Str -> V ;
mkV060 base =
  case base of {
    base_1+"je"+base_2@(?+?) =>
      let
        presS : Str = base_1+"je"+base_2 ;
        aorS  : Str = base_1+"o"+base_2+"j" ;     -- so that +a gives ...ja as in original
        impS  : Str = presS ;
        part  : Str = base_1+"je"+base_2+"ë" ;
        partStem : Str = base_1+"je"+base_2 ;
        optBase : Str = aorS ;
        optSh : Str = optBase+"sh" ;
      in lin V {
        Indicative = table {
          Pres => table {
            Sg => table { P1 => presS ; P2 => presS ; P3 => presS } ;
            Pl => table { P1 => presS+"im" ; P2 => presS+"ni" ; P3 => presS+"in" }
          } ;
