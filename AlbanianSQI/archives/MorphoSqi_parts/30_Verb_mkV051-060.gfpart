mkV060 : Str -> V ;
mkV060 base =
  case base of {
    base_1 + "je" + base_2@(?+?) =>
      let pres1 = base_1 + "je" + base_2 ;
          aor1  = base_1 + "o"  + base_2 + "ja" ;
          pple  = base_1 + "je" + base_2 + "ë" ;
          impSt = base_1 + "i"  + base_2
      in lin V {
        Indicative = table {
          Pres      => mkPresCons pres1 ;
          Past      => mkPerfTable pple ;
          Aorist    => mkAorTable aor1 ;
          Imperfect => mkImperfCons impSt
        } ;
        Imperative = mkImperativeBare impSt ;
        participle = pple ;
        pres_optative = mkOptFromAor1 aor1 ;
        perf_optative = mkPerfOpt pple ;
        pres_admirative = mkAdmPres pple ;
