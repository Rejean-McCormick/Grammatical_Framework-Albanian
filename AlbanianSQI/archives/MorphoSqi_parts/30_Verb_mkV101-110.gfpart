mkV106 : Str -> V ;
mkV106 base =
  case base of {
    base_1+"ë" =>
      let
        pres1 = base_1+"ë" ;
        pple  = base_1+"a" ;
        shortP = base_1 ;
      in lin V {
        Indicative = table {
          Pres      => mkPers pres1 pres1 pres1 (base_1+"ëmë") (base_1+"ëni") (base_1+"ënë") ;
          Past      => mkPerf pple ;
          Aorist    => mkAorCons base_1 ;
          Imperfect => mkImpf base_1
        } ;
        Imperative = table { Sg => pres1 ; Pl => base_1+"ëni" } ;
        participle = pple ;
        pres_optative   => mkOptFsh base_1 ;
        perf_optative   => mkPerfOpt pple ;
        pres_admirative => mkAdmPres shortP ;
        imperf_admirative => mkAdmImpf shortP
      } ;
    _ => error "Can't apply paradigm mkV106"
  } ;

mkV107 : Str -> V ;
mkV107 base =
  case base of {
    "n"+base_1 =>
      let
        pres1 = "n"+base_1 ;
        pple  = "n"+base_1+"ur" ;
        shortP = "n"+base_1+"u" ;  -- drop final -r
      in lin V {
        Indicative = table {
          Pres      => mkPers pres1 nonExist nonExist nonExist nonExist nonExist ;
          Past      => mkPerf pple ;
          Aorist    => mkAorCons base_1 ;
          Imperfect => mkImpf base_1
        } ;
        Imperative = table { Sg => nonExist ; Pl => nonExist } ;
        participle = pple ;
        pres_optative   => mkOptFsh base_1 ;
        perf_optative   => mkPerfOpt pple ;
        pres_admirative => mkAdmPres shortP ;
        imperf_admirative => mkAdmImpf shortP
      } ;
    _ => error "Can't apply paradigm mkV107"
  } ;

