mkV104 : Str -> V ;
mkV104 base =
  case base of {
    base_1+"on" =>
      let
        root    = base_1 ;
        impStem = root+"o" ;
        pple    = root+"uar" ;
        shortP  = root+"ua" ;  -- drop final -r
      in lin V {
        Indicative = table {
          Pres      => mkPresOj root ;
          Past      => mkPerf pple ;
          Aorist    => mkAorOj root ;
          Imperfect => mkImpf impStem
        } ;
        Imperative = table { Sg => root+"o" ; Pl => root+"oni" } ;
        participle = pple ;
        pres_optative   => mkOptFsh impStem ;
        perf_optative   => mkPerfOpt pple ;
        pres_admirative => mkAdmPres shortP ;
        imperf_admirative => mkAdmImpf shortP
      } ;
    _ => error "Can't apply paradigm mkV104"
  } ;

