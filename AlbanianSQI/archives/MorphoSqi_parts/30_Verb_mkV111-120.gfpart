mkV111 : Str -> V ;
mkV111 base_1 =
  lin V
  { Indicative = table {
                   Pres => table {
                             Sg => table {
                                     P1 => base_1+"j" ;
                                     P2 => base_1+"n" ;
                                     P3 => base_1+"n"
                                   } ;
                             Pl => table {
                                     P1 => base_1+"jmë" ;
                                     P2 => base_1+"ni" ;
                                     P3 => base_1+"jnë"
                                   }
                           } ;
                   Past => table {
                             Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                             Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                           } ;
                   Aorist => table {
                               Sg => table {
                                       P1 => base_1+"va" ;
                                       P2 => base_1+"ve" ;
                                       P3 => base_1+"i"
                                     } ;
                               Pl => table {
                                       P1 => base_1+"më" ;
                                       P2 => base_1+"të" ;
                                       P3 => base_1+"në"
                                     }
                             } ;
                   Imperfect => table {
                                  Sg => table {
                                          P1 => base_1+"ja" ;
                                          P2 => base_1+"je" ;
                                          P3 => base_1+"nte"
                                        } ;
                                  Pl => table {
                                          P1 => base_1+"nim" ;
                                          P2 => base_1+"nit" ;
                                          P3 => base_1+"nin"
                                        }
                                }
                 } ;
    Imperative = table {
                   Sg => base_1 ;
                   Pl => base_1+"ni"
                 } ;
    participle = base_1+"er" ;
    pres_optative = table {
                      Sg => table {
                              P1 => base_1+"fsha" ;
                              P2 => base_1+"fsh" ;
                              P3 => base_1+"ftë"
                            } ;
                      Pl => table {
                              P1 => base_1+"fshim" ;
                              P2 => base_1+"fshi" ;
                              P3 => base_1+"fshin"
                            }
                    } ;
    perf_optative = table {
                      Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                      Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                    } ;
    pres_admirative = table {
                        Sg => table {
                                P1 => (base_1+"er")+"kam" ;
                                P2 => (base_1+"er")+"ke" ;
                                P3 => (base_1+"er")+"ka"
                              } ;
                        Pl => table {
                                P1 => (base_1+"er")+"kemi" ;
                                P2 => (base_1+"er")+"keni" ;
                                P3 => (base_1+"er")+"kan"
                              }
                      } ;
    imperf_admirative = table {
                          Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                          Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                        }
  } ;


mkV112 : Str -> V ;
mkV112 base =
  case base of {
    base_1+"a"+base_2@(?+?) => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"a"+base_2 ;
                                         P2 => base_1+"e"+base_2 ;
                                         P3 => base_1+"e"+base_2
                                       } ;
                                 Pl => table {
                                         P1 => base_1+"a"+base_2+"im" ;
                                         P2 => base_1+"i"+base_2+"ni" ;
                                         P3 => base_1+"a"+base_2+"in"
                                       }
                               } ;
                       Past => table {
                                 Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                                 Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+"o"+base_2+"a" ;
                                           P2 => base_1+"o"+base_2+"e" ;
                                           P3 => base_1+"o"+base_2+"i"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"o"+base_2+"ëm" ;
                                           P2 => base_1+"o"+base_2+"ët" ;
                                           P3 => base_1+"o"+base_2+"ën"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+"i"+base_2+"ja" ;
                                              P2 => base_1+"i"+base_2+"je" ;
                                              P3 => base_1+"i"+base_2+"te"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+"i"+base_2+"nim" ;
                                              P2 => base_1+"i"+base_2+"nit" ;
                                              P3 => base_1+"i"+base_2+"nin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"i"+base_2 ;
                       Pl => base_1+"i"+base_2+"ni"
                     } ;
        participle = base_1+"a"+base_2+"ë" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => base_1+"o"+base_2+"sha" ;
                                  P2 => base_1+"o"+base_2+"sh" ;
                                  P3 => base_1+"o"+base_2+"të"
                                } ;
                          Pl => table {
                                  P1 => base_1+"o"+base_2+"shim" ;
                                  P2 => base_1+"o"+base_2+"shi" ;
                                  P3 => base_1+"o"+base_2+"shin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                          Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => (base_1+"a"+base_2+"ë")+"kam" ;
                                    P2 => (base_1+"a"+base_2+"ë")+"ke" ;
                                    P3 => (base_1+"a"+base_2+"ë")+"ka"
                                  } ;
                            Pl => table {
                                    P1 => (base_1+"a"+base_2+"ë")+"kemi" ;
                                    P2 => (base_1+"a"+base_2+"ë")+"keni" ;
                                    P3 => (base_1+"a"+base_2+"ë")+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                              Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                            }
      };
    _ => error "Can't apply paradigm mkV112"
  } ;


