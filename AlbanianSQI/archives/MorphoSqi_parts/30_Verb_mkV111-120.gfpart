                                    P1 => (base_1+"ënë")+"kam" ;
                                    P2 => (base_1+"ënë")+"ke" ;
                                    P3 => (base_1+"ënë")+"ka"
                                  } ;
                            Pl => table {
                                    P1 => (base_1+"ënë")+"kemi" ;
                                    P2 => (base_1+"ënë")+"keni" ;
                                    P3 => (base_1+"ënë")+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                              Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                            }
      };
    _ => error "Can't apply paradigm mkV118"
  } ;


mkV119 : Str -> V ;
mkV119 base =
  case base of {
    base_1+"ej" => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"ej" ;
                                         P2 => base_1+"en" ;
                                         P3 => base_1+"en"
                                       } ;
                                 Pl => table {
                                         P1 => base_1+"ejmë" ;
                                         P2 => base_1+"eni" ;
                                         P3 => base_1+"ejnë"
                                       }
                               } ;
                       Past => table {
                                 Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                                 Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+"eva" ;
                                           P2 => base_1+"eve" ;
                                           P3 => base_1+"evi"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+"evëm" ;
                                           P2 => base_1+"evët" ;
                                           P3 => base_1+"evën"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => base_1+"eja" ;
                                              P2 => base_1+"eje" ;
                                              P3 => base_1+"ente"
                                            } ;
                                      Pl => table {
                                              P1 => base_1+"enim" ;
                                              P2 => base_1+"enit" ;
                                              P3 => base_1+"enin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"ej" ;
                       Pl => base_1+"eni"
                     } ;
        participle = base_1+"yrë" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => (base_1+"e")+"fsha" ;
                                  P2 => (base_1+"e")+"fsh" ;
                                  P3 => (base_1+"e")+"ftë"
                                } ;
                          Pl => table {
                                  P1 => (base_1+"e")+"fshim" ;
                                  P2 => (base_1+"e")+"fshi" ;
                                  P3 => (base_1+"e")+"fshin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                          Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => (base_1+"yrë")+"kam" ;
                                    P2 => (base_1+"yrë")+"ke" ;
                                    P3 => (base_1+"yrë")+"ka"
                                  } ;
                            Pl => table {
                                    P1 => (base_1+"yrë")+"kemi" ;
                                    P2 => (base_1+"yrë")+"keni" ;
                                    P3 => (base_1+"yrë")+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                              Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                            }
      };
    _ => error "Can't apply paradigm mkV119"
  } ;


mkV120 : Str -> V ;
mkV120 base =
  case base of {
    base_1+"h"+base_2@(?+?+?) => lin V
      { Indicative = table {
                       Pres => table {
                                 Sg => table {
                                         P1 => base_1+"h"+base_2 ;
                                         P2 => base_1+"h"+base_2 ;
                                         P3 => base_1+"h"+base_2
                                       } ;
                                 Pl => table {
                                         P1 => (base_1+"h"+base_2)+"im" ;
                                         P2 => (base_1+"h"+base_2)+"ni" ;
                                         P3 => (base_1+"h"+base_2)+"in"
                                       }
                               } ;
                       Past => table {
                                 Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                                 Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                               } ;
                       Aorist => table {
                                   Sg => table {
                                           P1 => base_1+base_2+"a" ;
                                           P2 => base_1+base_2+"e" ;
                                           P3 => base_1+base_2+"i"
                                         } ;
                                   Pl => table {
                                           P1 => base_1+base_2+"ëm" ;
                                           P2 => base_1+base_2+"ët" ;
                                           P3 => base_1+base_2+"ën"
                                         }
                                 } ;
                       Imperfect => table {
                                      Sg => table {
                                              P1 => (base_1+"h"+base_2)+"ja" ;
                                              P2 => (base_1+"h"+base_2)+"je" ;
                                              P3 => (base_1+"h"+base_2)+"te"
                                            } ;
                                      Pl => table {
                                              P1 => (base_1+"h"+base_2)+"nim" ;
                                              P2 => (base_1+"h"+base_2)+"nit" ;
                                              P3 => (base_1+"h"+base_2)+"nin"
                                            }
                                    }
                     } ;
        Imperative = table {
                       Sg => base_1+"h"+base_2 ;
                       Pl => (base_1+"h"+base_2)+"ni"
                     } ;
        participle = base_1+"h"+base_2+"ur" ;
        pres_optative = table {
                          Sg => table {
                                  P1 => (base_1+base_2)+"sha" ;
                                  P2 => (base_1+base_2)+"sh" ;
                                  P3 => (base_1+base_2)+"të"
                                } ;
                          Pl => table {
                                  P1 => (base_1+base_2)+"shim" ;
                                  P2 => (base_1+base_2)+"shi" ;
                                  P3 => (base_1+base_2)+"shin"
                                }
                        } ;
        perf_optative = table {
                          Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                          Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                        } ;
        pres_admirative = table {
                            Sg => table {
                                    P1 => (base_1+"h"+base_2+"ur")+"kam" ;
                                    P2 => (base_1+"h"+base_2+"ur")+"ke" ;
                                    P3 => (base_1+"h"+base_2+"ur")+"ka"
                                  } ;
                            Pl => table {
                                    P1 => (base_1+"h"+base_2+"ur")+"kemi" ;
                                    P2 => (base_1+"h"+base_2+"ur")+"keni" ;
                                    P3 => (base_1+"h"+base_2+"ur")+"kan"
                                  }
                          } ;
        imperf_admirative = table {
                              Sg => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist } ;
                              Pl => table { P1 => nonExist ; P2 => nonExist ; P3 => nonExist }
                            }
      };
    _ => error "Can't apply paradigm mkV120"
  } ;